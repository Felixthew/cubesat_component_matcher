isplay: none;\r\n            text-align: center;\r\n            padding: 1rem;\r\n            color: #6b7280;\r\n            font-style: italic;\r\n        }\r\n\r\n        .loading-indicator.show {\r\n            display: block;\r\n        }\r\n\r\n        .spec-value-container {\r\n            position: relative;\r\n        }\r\n\r\n        .spec-search-input {\r\n            width: 100%;\r\n            padding: 0.75rem;\r\n            border: 2px solid #d1d5db;\r\n            border-radius: 8px;\r\n            font-size: 1rem;\r\n        }\r\n\r\n        .spec-search-input:focus {\r\n            outline: none;\r\n            border-color: #4f46e5;\r\n            box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);\r\n        }\r\n\r\n        .spec-multi-select {\r\n            position: absolute;\r\n            top: 100%;\r\n            left: 0;\r\n            right: 0;\r\n            z-index: 100;\r\n            background: white;\r\n            border: 1px solid #d1d5db;\r\n            border-top: none;\r\n            border-radius: 0 0 8px 8px;\r\n            max-height: 200px;\r\n            overflow-y: auto;\r\n            box-shadow: 0 4px 6px rgba(0,0,0,0.1);\r\n            display: none;\r\n        }\r\n\r\n        .spec-multi-option {\r\n            padding: 0.5rem;\r\n            cursor: pointer;\r\n            border-bottom: 1px solid #f3f4f6;\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 0.5rem;\r\n        }\r\n\r\n        .spec-multi-option:hover {\r\n            background: #f3f4f6;\r\n        }\r\n\r\n        .spec-multi-option:last-child {\r\n            border-bottom: none;\r\n        }\r\n\r\n        .spec-multi-option input[type=\"checkbox\"] {\r\n            width: auto;\r\n            height: auto;\r\n            padding: 0;\r\n            margin: 0;\r\n        }\r\n\r\n        .spec-selected-items {\r\n            display: none;\r\n        }\r\n\r\n        .spec-selected-tag {\r\n            background: #e0e7ff;\r\n            color: #3730a3;\r\n            padding: 0.25rem 0.5rem;\r\n            border-radius: 4px;\r\n            font-size: 0.8rem;\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 0.25rem;\r\n        }\r\n\r\n        .spec-selected-tag button {\r\n            background: none;\r\n            border: none;\r\n            color: #3730a3;\r\n            cursor: pointer;\r\n            padding: 0;\r\n            width: auto;\r\n            font-size: 0.7rem;\r\n            line-height: 1;\r\n        }\r\n\r\n        .results-table-container {\r\n            overflow-x: auto;\r\n            overflow-y: visible;\r\n            border: 1px solid #e5e7eb;\r\n            border-radius: 8px;\r\n            background: white;\r\n            box-shadow: 0 4px 6px rgba(0,0,0,0.05);\r\n            width: 100%;\r\n        }\r\n\r\n        .results-table {\r\n            width: max-content;\r\n            min-width: 100%;\r\n            border-collapse: collapse;\r\n            background: white;\r\n            margin: 0;\r\n        }\r\n\r\n        .results-table th,\r\n        .results-table td {\r\n            padding: 1rem;\r\n            text-align: left;\r\n            border-bottom: 1px solid #e5e7eb;\r\n        }\r\n\r\n        .results-table th {\r\n            background: #f3f4f6;\r\n            font-weight: 600;\r\n            color: #374151;\r\n        }\r\n\r\n        .results-table tr:hover {\r\n            background: #f9fafb;\r\n        }\r\n\r\n        .loading {\r\n            text-align: center;\r\n            padding: 2rem;\r\n            color: #6b7280;\r\n        }\r\n\r\n        .error {\r\n            background: #fef2f2;\r\n            border: 1px solid #fecaca;\r\n            color: #dc2626;\r\n            padding: 1rem;\r\n            border-radius: 8px;\r\n            margin: 1rem 0;\r\n        }\r\n\r\n        .success {\r\n            background: #f0fdf4;\r\n            border: 1px solid #bbf7d0;\r\n            color: #16a34a;\r\n            padding: 1rem;\r\n            border-radius: 8px;\r\n            margin: 1rem 0;\r\n        }\r\n\r\n        .hidden {\r\n            display: none;\r\n        }\r\n\r\n        .grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\r\n            gap: 1rem;\r\n        }\r\n\r\n        .filter-item {\r\n            margin-bottom: 1rem;\r\n        }\r\n\r\n        .filter-controls-row {\r\n            display: flex;\r\n            gap: 0.5rem;\r\n            margin-top: 0.5rem;\r\n            align-items: center;\r\n        }\r\n\r\n        .filter-controls-row input[type=\"number\"] {\r\n            flex: 1;\r\n        }\r\n\r\n        .filter-controls-row button {\r\n            width: auto;\r\n            padding: 0.5rem;\r\n            background: #ef4444;\r\n            font-size: 0.8rem;\r\n            color: white;\r\n            border: none;\r\n            border-radius: 4px;\r\n            cursor: pointer;\r\n        }\r\n\r\n        .kwargs-item {\r\n            display: grid;\r\n            grid-template-columns: 1.5fr 2fr 2fr 1.5fr auto;\r\n            gap: 0.5rem;\r\n            margin-bottom: 0.5rem;\r\n            align-items: end;\r\n        }\r\n\r\n        .info-icon {\r\n            display: inline-block;\r\n            width: 16px;\r\n            height: 16px;\r\n            background: #6b7280;\r\n            border-radius: 50%;\r\n            color: white;\r\n            text-align: center;\r\n            font-size: 12px;\r\n            line-height: 16px;\r\n            cursor: help;\r\n            margin-left: 4px;\r\n            position: relative;\r\n        }\r\n\r\n        .info-tooltip {\r\n            position: absolute;\r\n            bottom: 100%;\r\n            left: 0;\r\n            right: 0;\r\n            margin-bottom: 5px;\r\n            background: #1f2937;\r\n            color: white;\r\n            padding: 8px 12px;\r\n            border-radius: 6px;\r\n            font-size: 12px;\r\n            white-space: normal;\r\n            z-index: 1000;\r\n            opacity: 0;\r\n            pointer-events: none;\r\n            transition: opacity 0.2s;\r\n            box-shadow: 0 4px 6px rgba(0,0,0,0.3);\r\n            width: 100%;\r\n            box-sizing: border-box;\r\n        }\r\n\r\n        .info-tooltip::before {\r\n            content: '';\r\n            position: absolute;\r\n            top: 100%;\r\n            left: 50%;\r\n            transform: translateX(-50%);\r\n            border: 5px solid transparent;\r\n            border-top-color: #1f2937;\r\n        }\r\n\r\n        .param-option-with-info {\r\n            position: relative;\r\n            display: flex;\r\n            align-items: center;\r\n            justify-content: space-between;\r\n            width: 100%;\r\n        }\r\n\r\n        .param-option-with-info:hover .info-tooltip {\r\n            opacity: 1;\r\n        }\r\n\r\n        @media (max-width: 768px) {\r\n            .spec-item {\r\n                grid-template-columns: 1fr;\r\n            }\r\n\r\n            .header h1 {\r\n                font-size: 2rem;\r\n            }\r\n\r\n            .content {\r\n                padding: 1rem;\r\n            }\r\n        }\r\n\r\n        // Helper function to get value from value container (handles different input types)\r\n        function getValueFromContainer(container) {\r\n            // Check for additional select elements (boolean dropdown or options dropdown)\r\n            // Look for selects that are not the first 3 main selects in the kwargs item\r\n            const parentItem = container.closest('.kwargs-item');\r\n            const extraSelects = parentItem.querySelectorAll('select:not(:nth-child(1)):not(:nth-child(2)):not(:nth-child(3))');\r\n\r\n            if (extraSelects.length > 0 && extraSelects[0].style.display !== 'none') {\r\n                const value = extraSelects[0].value;\r\n                if (value === 'true') return true;\r\n                if (value === 'false') return false;\r\n                return value || null;\r\n            }\r\n\r\n            // Check for regular input (if it's the valueInput itself)\r\n            if (container.tagName === 'INPUT' && container.style.display !== 'none') {\r\n                if (container.type === 'number') {\r\n                    return container.value ? parseFloat(container.value) : null;\r\n                }\r\n                return container.value || null;\r\n            }\r\n\r\n            return null;\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div class=\"container\">\r\n        <div class=\"header\">\r\n            <h1>Component Matcher</h1>\r\n            <p>Find and score components based on your specifications</p>\r\n        </div>\r\n\r\n        <div class=\"content\">\r\n            <!-- Step 1: Select Solution -->\r\n            <div class=\"section\">\r\n                <h2>1. Select Solution Type</h2>\r\n                <div class=\"form-group\">\r\n                    <label for=\"solutionSelect\">Choose a solution category:</label>\r\n                    <select id=\"solutionSelect\">\r\n                        <option value=\"\">Loading solutions...</option>\r\n                    </select>\r\n                </div>\r\n            </div>\r\n\r\n            <!-- Step 2: Select System -->\r\n            <div class=\"section hidden\" id=\"systemSection\">\r\n                <h2>2. Select System Type</h2>\r\n                <div class=\"loading-indicator\" id=\"systemLoadingIndicator\">Loading systems...</div>\r\n                <div class=\"form-group\">\r\n                    <label for=\"systemSelect\">Choose a system:</label>\r\n                    <select id=\"systemSelect\">\r\n                        <option value=\"\">Select a solution first</option>\r\n                    </select>\r\n                </div>\r\n            </div>\r\n\r\n            <!-- Step 3: Configure Specifications -->\r\n            <div class=\"section hidden\" id=\"specsSection\">\r\n                <h2>3. Configure Specifications</h2>\r\n                <div class=\"loading-indicator\" id=\"specsLoadingIndicator\">Loading parameters...</div>\r\n                <div class=\"specs-container\">\r\n                    <div id=\"specsContainer\">\r\n                        <!-- Specs will be added here dynamically -->\r\n                    </div>\r\n                    <button type=\"button\" class=\"add-btn\" id=\"addSpecBtn\">Add Specification</button>\r\n                </div>\r\n                <button type=\"button\" id=\"searchBtn\" style=\"margin-top: 1rem;\">Search Components</button>\r\n            </div>\r\n\r\n            <!-- Step 4: Configure Scoring Parameters (Optional) -->\r\n            <div class=\"section hidden\" id=\"kwargsSection\">\r\n                <h2>4. Configure Scoring Parameters (Optional)</h2>\r\n                <div class=\"kwargs-container\">\r\n                    <div id=\"kwargsContainer\">\r\n                        <!-- Kwargs will be added here -->\r\n                    </div>\r\n                    <button type=\"button\" class=\"add-btn\" id=\"addKwargBtn\">Add Scoring Parameter</button>\r\n                </div>\r\n            </div>\r\n\r\n            <!-- Results Section -->\r\n            <div class=\"section hidden\" id=\"resultsSection\">\r\n                <h2>Results</h2>\r\n\r\n                <!-- Filters and Sorting Controls -->\r\n                <div class=\"hidden\" id=\"resultControls\">\r\n                    <div class=\"grid\" style=\"margin-bottom: 1rem;\">\r\n                        <div>\r\n                            <h3>Filter Results</h3>\r\n                            <div id=\"filtersContainer\">\r\n                                <!-- Filters will be added here -->\r\n                            </div>\r\n                            <button type=\"button\" class=\"add-btn\" id=\"addFilterBtn\">Add Filter</button>\r\n                        </div>\r\n\r\n                        <div>\r\n                            <h3>Sort Results</h3>\r\n                            <div class=\"form-group\">\r\n                                <label for=\"sortBySelect\">Sort by:</label>\r\n                                <select id=\"sortBySelect\">\r\n                                    <option value=\"overall_score\">Overall Score</option>\r\n                                </select>\r\n                            </div>\r\n                            <div class=\"form-group\" style=\"display: flex; align-items: center; gap: 0.3rem; white-space: nowrap;\">\r\n                                <label for=\"sortAscCheckbox\" style=\"margin: 0;\">Sort ascending</label>\r\n                                <input type=\"checkbox\" id=\"sortAscCheckbox\">\r\n                            </div>\r\n                            <div class=\"form-group\" style=\"display: flex; align-items: center; gap: 0.3rem; white-space: nowrap;\">\r\n                                <label for=\"scoreCouplingCheckbox\" style=\"margin: 0;\">Score coupling</label>\r\n                                <input type=\"checkbox\" id=\"scoreCouplingCheckbox\">\r\n                            </div>\r\n                        </div>\r\n\r\n                        <div>\r\n                            <h3>Pagination</h3>\r\n                            <div class=\"form-group\">\r\n                                <label for=\"pageInput\">Page:</label>\r\n                                <input type=\"number\" id=\"pageInput\" value=\"1\" min=\"1\">\r\n                            </div>\r\n                            <div class=\"form-group\">\r\n                                <label for=\"perPageSelect\">Results per page:</label>\r\n                                <select id=\"perPageSelect\">\r\n                                    <option value=\"10\">10</option>\r\n                                    <option value=\"25\">25</option>\r\n                                    <option value=\"50\">50</option>\r\n                                    <option value=\"100\">100</option>\r\n                                </select>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <button type=\"button\" id=\"applyFiltersBtn\">Apply Filters & Sorting</button>\r\n                </div>\r\n\r\n                <div class=\"results-container\" id=\"resultsContainer\">\r\n                    <!-- Results will be displayed here -->\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <script>\r\n        const API_BASE = 'http://localhost:8000'; // Change this to your API URL\r\n\r\n        let currentSolution = '';\r\n        let currentSystem = '';\r\n        let availableColumns = [];\r\n        let currentSessionId = '';\r\n        let allResultColumns = [];\r\n        let availableDataTypes = new Set();\r\n        let globalKwargProfiles = {}; // kwargs organized by data type\r\n        let selectedSpecs = new Set(); // track which columns are being scored\r\n\r\n        // Initialize the application\r\n        async function init() {\r\n            await loadSolutions();\r\n            await loadGlobalKwargProfiles();\r\n        }\r\n\r\n        // Load available solutions\r\n        async function loadSolutions() {\r\n            try {\r\n                const response = await fetch(`${API_BASE}/options`);\r\n                const data = await response.json();\r\n\r\n                const select = document.getElementById('solutionSelect');\r\n                select.innerHTML = '<option value=\"\">Select a solution...</option>';\r\n\r\n                data.schemas.forEach(schema => {\r\n                    // Filter out metadata and pg_toast schemas\r\n                    if (schema !== 'metadata' && schema !== 'pg_toast') {\r\n                        const option = document.createElement('option');\r\n                        option.value = schema;\r\n                        option.textContent = schema;\r\n                        select.appendChild(option);\r\n                    }\r\n                });\r\n            } catch (error) {\r\n                showError('Failed to load solutions: ' + error.message);\r\n            }\r\n        }\r\n\r\n        // Load global kwargs profiles\r\n        async function loadGlobalKwargProfiles() {\r\n            try {\r\n                const response = await fetch(`${API_BASE}/kwargs`);\r\n                const data = await response.json();\r\n                globalKwargProfiles = data;\r\n            } catch (error) {\r\n                console.warn('Failed to load global kwargs profiles:', error.message);\r\n                globalKwargProfiles = {};\r\n            }\r\n        }\r\n\r\n        // Load systems for selected solution\r\n        async function loadSystems(solution) {\r\n            try {\r\n                // Reset subsequent sections when solution changes\r\n                resetSystemAndBelow();\r\n\r\n                // Show loading indicator\r\n                document.getElementById('systemSection').classList.remove('hidden');\r\n                document.getElementById('systemLoadingIndicator').classList.add('show');\r\n\r\n                const response = await fetch(`${API_BASE}/options/${solution}`);\r\n                const data = await response.json();\r\n\r\n                const select = document.getElementById('systemSelect');\r\n                select.innerHTML = '<option value=\"\">Select a system...</option>';\r\n\r\n                data.tables.forEach(table => {\r\n                    const option = document.createElement('option');\r\n                    option.value = table;\r\n                    option.textContent = table;\r\n                    select.appendChild(option);\r\n                });\r\n\r\n                // Hide loading indicator\r\n                document.getElementById('systemLoadingIndicator').classList.remove('show');\r\n\r\n            } catch (error) {\r\n                document.getElementById('systemLoadingIndicator').classList.remove('show');\r\n                showError('Failed to load systems: ' + error.message);\r\n            }\r\n        }\r\n\r\n        // Reset system selection and everything below it\r\n        function resetSystemAndBelow() {\r\n            document.getElementById('systemSelect').innerHTML = '<option value=\"\">Select a system...</option>';\r\n            document.getElementById('specsSection').classList.add('hidden');\r\n            document.getElementById('kwargsSection').classList.add('hidden');\r\n            resetResultsAndBelow();\r\n            currentSystem = '';\r\n            availableColumns = [];\r\n            availableDataTypes.clear();\r\n        }\r\n\r\n        // Load parameters for selected system\r\n        async function loadParameters(solution, system) {\r\n            try {\r\n                // Reset everything below this level\r\n                resetResultsAndBelow();\r\n\r\n                // Show loading indicator\r\n                document.getElementById('specsSection').classList.remove('hidden');\r\n                document.getElementById('specsLoadingIndicator').classList.add('show');\r\n\r\n                const response = await fetch(`${API_BASE}/options/${solution}/${system}`);\r\n                const data = await response.json();\r\n\r\n                availableColumns = data.columns;\r\n\r\n                // Collect unique data types\r\n                availableDataTypes.clear();\r\n                data.columns.forEach(col => {\r\n                    availableDataTypes.add(col.dtype);\r\n                });\r\n\r\n                setupSpecsSection();\r\n                setupKwargsSection();\r\n\r\n                // Hide loading indicator\r\n                document.getElementById('specsLoadingIndicator').classList.remove('show');\r\n\r\n            } catch (error) {\r\n                document.getElementById('specsLoadingIndicator').classList.remove('show');\r\n                showError('Failed to load parameters: ' + error.message);\r\n            }\r\n        }\r\n\r\n        // Reset results and everything below\r\n        function resetResultsAndBelow() {\r\n            document.getElementById('resultsSection').classList.add('hidden');\r\n            document.getElementById('resultControls').classList.add('hidden');\r\n            currentSessionId = '';\r\n            allResultColumns = [];\r\n        }\r\n\r\n        // Setup specifications section\r\n        function setupSpecsSection() {\r\n            // Reset results when specs change\r\n            resetResultsAndBelow();\r\n\r\n            const container = document.getElementById('specsContainer');\r\n            container.innerHTML = '';\r\n            addSpecificationRow();\r\n        }\r\n\r\n        // Setup kwargs section\r\n        function setupKwargsSection() {\r\n            document.getElementById('kwargsSection').classList.remove('hidden');\r\n\r\n            const container = document.getElementById('kwargsContainer');\r\n            container.innerHTML = '';\r\n        }\r\n\r\n        // Add a specification row\r\n        function addSpecificationRow() {\r\n            const container = document.getElementById('specsContainer');\r\n            const specItem = document.createElement('div');\r\n            specItem.className = 'spec-item';\r\n\r\n            // Get already used parameters to prevent duplicates\r\n            const usedParams = Array.from(container.querySelectorAll('.spec-item select')).map(select => select.value).filter(val => val);\r\n\r\n            const paramSelect = document.createElement('select');\r\n            paramSelect.innerHTML = '<option value=\"\">Select parameter...</option>';\r\n            availableColumns.forEach(col => {\r\n                // Only add if not already used\r\n                if (!usedParams.includes(col.name)) {\r\n                    const option = document.createElement('option');\r\n                    option.value = col.name;\r\n                    option.textContent = `${col.name} (${col.dtype})`;\r\n                    paramSelect.appendChild(option);\r\n                }\r\n            });\r\n\r\n            const valueContainer = document.createElement('div');\r\n            valueContainer.className = 'spec-value-container';\r\n\r\n            const valueInput = document.createElement('input');\r\n            valueInput.type = 'text';\r\n            valueInput.placeholder = 'Value';\r\n            valueInput.className = 'spec-search-input';\r\n            valueInput.readOnly = true; // Make it read-only for multi-select\r\n\r\n            const multiSelectDiv = document.createElement('div');\r\n            multiSelectDiv.className = 'spec-multi-select';\r\n\r\n            const selectedItemsDiv = document.createElement('div');\r\n            selectedItemsDiv.className = 'spec-selected-items';\r\n\r\n            valueContainer.appendChild(valueInput);\r\n            valueContainer.appendChild(selectedItemsDiv);\r\n            valueContainer.appendChild(multiSelectDiv);\r\n\r\n            // Setup search functionality\r\n            let currentOptions = [];\r\n            let selectedValues = [];\r\n            let isMultiSelect = false;\r\n\r\n            // Update options when parameter changes\r\n            paramSelect.addEventListener('change', function() {\r\n                const selectedParam = availableColumns.find(col => col.name === this.value);\r\n                currentOptions = selectedParam?.options || [];\r\n                selectedValues = [];\r\n\r\n                // Check parameter type for input mode\r\n                if (selectedParam && selectedParam.dtype === 'boolean') {\r\n                    // Boolean parameters get a true/false dropdown\r\n                    isMultiSelect = false;\r\n                    currentOptions = ['true', 'false'];\r\n                    valueInput.placeholder = 'Click to select true/false';\r\n                    valueInput.readOnly = true;\r\n                } else if (selectedParam && selectedParam.dtype === 'list' && currentOptions.length > 0) {\r\n                    // List parameters get multi-select checkboxes\r\n                    isMultiSelect = true;\r\n                    valueInput.placeholder = 'Click to select options';\r\n                    valueInput.readOnly = true;\r\n                } else if (currentOptions.length > 0) {\r\n                    // String parameters with options get single-select dropdown\r\n                    isMultiSelect = false;\r\n                    valueInput.placeholder = 'Value (click to see options)';\r\n                    valueInput.readOnly = false;\r\n                } else {\r\n                    // Parameters without options get regular text input\r\n                    isMultiSelect = false;\r\n                    valueInput.placeholder = 'Value';\r\n                    valueInput.readOnly = false;\r\n                }\r\n\r\n                valueInput.value = '';\r\n                multiSelectDiv.style.display = 'none';\r\n                updateSelectedItems();\r\n\r\n                // Update other dropdowns to remove this selection\r\n                updateParameterDropdowns();\r\n                updateKwargsAvailability();\r\n            });\r\n\r\n            // Show multi-select when clicking on input (for multi-select mode)\r\n            valueInput.addEventListener('click', function() {\r\n                const selectedParam = availableColumns.find(col => col.name === paramSelect.value);\r\n\r\n                if (selectedParam && selectedParam.dtype === 'boolean') {\r\n                    // Show true/false dropdown for boolean parameters\r\n                    showBooleanSelect();\r\n                } else if (isMultiSelect && currentOptions.length > 0) {\r\n                    showMultiSelect();\r\n                } else if (!isMultiSelect && currentOptions.length > 0) {\r\n                    showSingleSelect();\r\n                }\r\n            });\r\n\r\n            // Handle comma-separated input for contains_any functionality\r\n            valueInput.addEventListener('input', function() {\r\n                if (!isMultiSelect && currentOptions.length > 0) {\r\n                    // Get the current input value\r\n                    const fullValue = this.value;\r\n\r\n                    // Check if this might be a comma-separated list (for contains_any)\r\n                    const lastCommaIndex = fullValue.lastIndexOf(',');\r\n                    let searchTerm = fullValue;\r\n                    let prefix = '';\r\n\r\n                    if (lastCommaIndex !== -1) {\r\n                        // Split at last comma\r\n                        prefix = fullValue.substring(0, lastCommaIndex + 1).trim() + ' ';\r\n                        searchTerm = fullValue.substring(lastCommaIndex + 1).trim();\r\n                    }\r\n\r\n                    showSingleSelect(searchTerm, prefix);\r\n                }\r\n            });\r\n\r\n            function showSingleSelect(query = '', prefix = '') {\r\n                multiSelectDiv.innerHTML = '';\r\n\r\n                if (currentOptions.length === 0) {\r\n                    multiSelectDiv.style.display = 'none';\r\n                    return;\r\n                }\r\n\r\n                const filteredOptions = query === '' ?\r\n                    currentOptions :\r\n                    currentOptions.filter(option =>\r\n                        option.toString().toLowerCase().includes(query.toLowerCase())\r\n                    );\r\n\r\n                if (filteredOptions.length === 0) {\r\n                    multiSelectDiv.style.display = 'none';\r\n                    return;\r\n                }\r\n\r\n                // Sort filtered options alphabetically\r\n                const sortedOptions = filteredOptions.sort((a, b) =>\r\n                    a.toString().localeCompare(b.toString())\r\n                );\r\n\r\n                sortedOptions.forEach(option => {\r\n                    const optionDiv = document.createElement('div');\r\n                    optionDiv.className = 'spec-multi-option';\r\n                    optionDiv.style.justifyContent = 'flex-start';\r\n\r\n                    const label = document.createElement('span');\r\n                    label.textContent = option;\r\n                    label.style.cursor = 'pointer';\r\n\r\n                    optionDiv.appendChild(label);\r\n\r\n                    optionDiv.addEventListener('click', function() {\r\n                        if (prefix) {\r\n                            // For comma-separated lists, append to existing content\r\n                            valueInput.value = prefix + option;\r\n                        } else {\r\n                            // Normal single selection\r\n                            valueInput.value = option;\r\n                        }\r\n                        multiSelectDiv.style.display = 'none';\r\n                    });\r\n\r\n                    multiSelectDiv.appendChild(optionDiv);\r\n                });\r\n\r\n                multiSelectDiv.style.display = 'block';\r\n            }\r\n\r\n            function showBooleanSelect() {\r\n                multiSelectDiv.innerHTML = '';\r\n\r\n                ['false', 'true'].forEach(option => {\r\n                    const optionDiv = document.createElement('div');\r\n                    optionDiv.className = 'spec-multi-option';\r\n                    optionDiv.style.justifyContent = 'flex-start';\r\n\r\n                    const label = document.createElement('span');\r\n                    label.textContent = option;\r\n                    label.style.cursor = 'pointer';\r\n\r\n                    optionDiv.appendChild(label);\r\n\r\n                    optionDiv.addEventListener('click', function() {\r\n                        valueInput.value = option;\r\n                        multiSelectDiv.style.display = 'none';\r\n                    });\r\n\r\n                    multiSelectDiv.appendChild(optionDiv);\r\n                });\r\n\r\n                multiSelectDiv.style.display = 'block';\r\n            }\r\n\r\n            function showMultiSelect() {\r\n                multiSelectDiv.innerHTML = '';\r\n\r\n                // Sort options alphabetically\r\n                const sortedOptions = [...currentOptions].sort((a, b) =>\r\n                    a.toString().localeCompare(b.toString())\r\n                );\r\n\r\n                sortedOptions.forEach(option => {\r\n                    const optionDiv = document.createElement('div');\r\n                    optionDiv.className = 'spec-multi-option';\r\n\r\n                    const checkbox = document.createElement('input');\r\n                    checkbox.type = 'checkbox';\r\n                    checkbox.checked = selectedValues.includes(option);\r\n\r\n                    const label = document.createElement('span');\r\n                    label.textContent = option;\r\n\r\n                    optionDiv.appendChild(checkbox);\r\n                    optionDiv.appendChild(label);\r\n\r\n                    optionDiv.addEventListener('click', function(e) {\r\n                        if (e.target.type !== 'checkbox') {\r\n                            checkbox.checked = !checkbox.checked;\r\n                        }\r\n                        toggleOption(option, checkbox.checked);\r\n                    });\r\n\r\n                    checkbox.addEventListener('change', function() {\r\n                        toggleOption(option, this.checked);\r\n                    });\r\n\r\n                    multiSelectDiv.appendChild(optionDiv);\r\n                });\r\n\r\n                multiSelectDiv.style.display = 'block';\r\n            }\r\n\r\n            function toggleOption(option, isSelected) {\r\n                if (isSelected) {\r\n                    if (!selectedValues.includes(option)) {\r\n                        selectedValues.push(option);\r\n                    }\r\n                } else {\r\n                    selectedValues = selectedValues.filter(val => val !== option);\r\n                }\r\n                updateSelectedItems();\r\n                updateInputValue();\r\n            }\r\n\r\n            function updateSelectedItems() {\r\n                // Hidden for now to clean up the interface\r\n                selectedItemsDiv.innerHTML = '';\r\n            }\r\n\r\n            function updateInputValue() {\r\n                if (isMultiSelect) {\r\n                    valueInput.value = selectedValues.join(', ');\r\n                }\r\n            }\r\n\r\n            // Hide multi-select when clicking outside\r\n            document.addEventListener('click', function(e) {\r\n                if (!valueContainer.contains(e.target)) {\r\n                    multiSelectDiv.style.display = 'none';\r\n                }\r\n            });\r\n\r\n            const weightInput = document.createElement('input');\r\n            weightInput.type = 'number';\r\n            weightInput.placeholder = 'Weight';\r\n            weightInput.value = '1';\r\n            weightInput.step = '0.1';\r\n            weightInput.min = '0.1';\r\n\r\n            const removeBtn = document.createElement('button');\r\n            removeBtn.textContent = '×';\r\n            removeBtn.className = 'remove-btn';\r\n            removeBtn.onclick = () => {\r\n                specItem.remove();\r\n                updateKwargsAvailability();\r\n            };\r\n\r\n            specItem.appendChild(paramSelect);\r\n            specItem.appendChild(valueContainer);\r\n            specItem.appendChild(weightInput);\r\n            specItem.appendChild(removeBtn);\r\n\r\n            container.appendChild(specItem);\r\n        }\r\n\r\n        // Update parameter dropdowns to prevent duplicates\r\n        function updateParameterDropdowns() {\r\n            const container = document.getElementById('specsContainer');\r\n            const allSelects = container.querySelectorAll('.spec-item select');\r\n            const usedParams = Array.from(allSelects).map(select => select.value).filter(val => val);\r\n\r\n            allSelects.forEach(select => {\r\n                const currentValue = select.value;\r\n                select.innerHTML = '<option value=\"\">Select parameter...</option>';\r\n\r\n                availableColumns.forEach(col => {\r\n                    // Add option if it's not used elsewhere OR it's the current selection\r\n                    if (!usedParams.includes(col.name) || col.name === currentValue) {\r\n                        const option = document.createElement('option');\r\n                        option.value = col.name;\r\n                        option.textContent = `${col.name} (${col.dtype})`;\r\n                        if (col.name === currentValue) option.selected = true;\r\n                        select.appendChild(option);\r\n                    }\r\n                });\r\n            });\r\n        }\r\n\r\n        // Update kwargs availability based on selected specs - now refreshes existing dropdowns\r\n        function updateKwargsAvailability() {\r\n            // Refresh all existing type and column selection dropdowns in kwargs\r\n            const kwargItems = document.querySelectorAll('#kwargsContainer .kwargs-item');\r\n\r\n            kwargItems.forEach(item => {\r\n                const typeSelect = item.children[0];  // kwarg type select\r\n                const selectionSelect = item.children[1];  // selection dropdown\r\n\r\n                const currentKwargType = typeSelect.value;\r\n                const currentSelection = selectionSelect.value;\r\n\r\n                // Only update if a kwarg type is selected\r\n                if (currentKwargType === 'type') {\r\n                    // Refresh with available data types\r\n                    populateSelectionWithTypes(selectionSelect);\r\n                    // Restore selection if it still exists\r\n                    if (currentSelection) {\r\n                        const optionExists = Array.from(selectionSelect.options).some(opt => opt.value === currentSelection);\r\n                        if (optionExists) {\r\n                            selectionSelect.value = currentSelection;\r\n                        }\r\n                    }\r\n                } else if (currentKwargType === 'column') {\r\n                    // Refresh with available columns\r\n                    populateSelectionWithColumns(selectionSelect);\r\n                    // Restore selection if it still exists\r\n                    if (currentSelection) {\r\n                        const optionExists = Array.from(selectionSelect.options).some(opt => opt.value === currentSelection);\r\n                        if (optionExists) {\r\n                            selectionSelect.value = currentSelection;\r\n                        }\r\n                    }\r\n                }\r\n            });\r\n\r\n            console.log('Kwargs dropdowns refreshed with current specifications');\r\n        }\r\n\r\n        // Helper function to get value from value container (handles different input types)\r\n        function getValueFromContainer(container) {\r\n            // Check for additional select elements (boolean dropdown or options dropdown)\r\n            // Look for selects that are not the first 3 main selects in the kwargs item\r\n            const parentItem = container.closest('.kwargs-item');\r\n            const extraSelects = parentItem.querySelectorAll('select:not(:nth-child(1)):not(:nth-child(2)):not(:nth-child(3))');\r\n\r\n            if (extraSelects.length > 0 && extraSelects[0].style.display !== 'none') {\r\n                const value = extraSelects[0].value;\r\n                if (value === 'true') return true;\r\n                if (value === 'false') return false;\r\n                return value || null;\r\n            }\r\n\r\n            // Check for regular input (if it's the valueInput itself)\r\n            if (container.tagName === 'INPUT' && container.style.display !== 'none') {\r\n                if (container.type === 'number') {\r\n                    return container.value ? parseFloat(container.value) : null;\r\n                }\r\n                return container.value || null;\r\n            }\r\n\r\n            return null;\r\n        }\r\n\r\n        // Helper function to populate selection with data types\r\n        function populateSelectionWithTypes(selectionSelect) {\r\n            const currentSpecs = getCurrentSelectedSpecs();\r\n            const usedDtypes = new Set();\r\n\r\n            currentSpecs.forEach(colName => {\r\n                const col = availableColumns.find(c => c.name === colName);\r\n                if (col) {\r\n                    usedDtypes.add(col.dtype);\r\n                }\r\n            });\r\n\r\n            selectionSelect.innerHTML = '<option value=\"\">Select data type...</option>';\r\n            if (usedDtypes.size === 0) {\r\n                const option = document.createElement('option');\r\n                option.value = '';\r\n                option.textContent = 'No specifications selected';\r\n                option.disabled = true;\r\n                selectionSelect.appendChild(option);\r\n            } else {\r\n                Array.from(usedDtypes).sort().forEach(dtype => {\r\n                    const option = document.createElement('option');\r\n                    option.value = dtype;\r\n                    option.textContent = dtype;\r\n                    selectionSelect.appendChild(option);\r\n                });\r\n            }\r\n        }\r\n\r\n        // Helper function to populate selection with columns\r\n        function populateSelectionWithColumns(selectionSelect) {\r\n            const currentSpecs = getCurrentSelectedSpecs();\r\n\r\n            selectionSelect.innerHTML = '<option value=\"\">Select column...</option>';\r\n            if (currentSpecs.length === 0) {\r\n                const option = document.createElement('option');\r\n                option.value = '';\r\n                option.textContent = 'No specifications selected';\r\n                option.disabled = true;\r\n                selectionSelect.appendChild(option);\r\n            } else {\r\n                currentSpecs.forEach(colName => {\r\n                    const col = availableColumns.find(c => c.name === colName);\r\n                    if (col) {\r\n                        const option = document.createElement('option');\r\n                        option.value = col.name;\r\n                        option.textContent = `${col.name} (${col.dtype})`;\r\n                        option.dataset.columnData = JSON.stringify(col);\r\n                        selectionSelect.appendChild(option);\r\n                    }\r\n                });\r\n            }\r\n        }\r\n\r\n        // Helper function to populate parameters based on type and selection\r\n        function populateParameters(paramSelect, kwargType, selectedItem, selectionElement) {\r\n            paramSelect.innerHTML = '<option value=\"\">Select parameter...</option>';\r\n\r\n            if (kwargType === 'type') {\r\n                // Type-wide: selectedItem is a dtype, show type-wide parameters\r\n                if (globalKwargProfiles[selectedItem]) {\r\n                    globalKwargProfiles[selectedItem].forEach(kwargProfile => {\r\n                        const option = document.createElement('option');\r\n                        option.value = kwargProfile.name;\r\n                        option.textContent = kwargProfile.name;\r\n                        option.dataset.kwargProfile = JSON.stringify(kwargProfile);\r\n                        paramSelect.appendChild(option);\r\n                    });\r\n                }\r\n            } else if (kwargType === 'column') {\r\n                // Column-specific: selectedItem is a column name\r\n                const selectedColData = JSON.parse(selectionElement.selectedOptions[0]?.dataset.columnData || '{}');\r\n\r\n                // Use a Set to track parameter names and avoid duplicates\r\n                const addedParams = new Set();\r\n\r\n                // First priority: column-specific kwargs if available\r\n                if (selectedColData.kwargs && selectedColData.kwargs.length > 0) {\r\n                    selectedColData.kwargs.forEach(kwargProfile => {\r\n                        if (!addedParams.has(kwargProfile.name)) {\r\n                            const option = document.createElement('option');\r\n                            option.value = kwargProfile.name;\r\n                            option.textContent = kwargProfile.name;\r\n                            option.dataset.kwargProfile = JSON.stringify(kwargProfile);\r\n                            paramSelect.appendChild(option);\r\n                            addedParams.add(kwargProfile.name);\r\n                        }\r\n                    });\r\n                }\r\n\r\n                // Second priority: type-wide kwargs for this column's data type (only if not already added)\r\n                if (selectedColData.dtype && globalKwargProfiles[selectedColData.dtype]) {\r\n                    globalKwargProfiles[selectedColData.dtype].forEach(kwargProfile => {\r\n                        if (!addedParams.has(kwargProfile.name)) {\r\n                            const option = document.createElement('option');\r\n                            option.value = kwargProfile.name;\r\n                            option.textContent = kwargProfile.name;\r\n                            option.dataset.kwargProfile = JSON.stringify(kwargProfile);\r\n                            paramSelect.appendChild(option);\r\n                            addedParams.add(kwargProfile.name);\r\n                        }\r\n                    });\r\n                }\r\n            }\r\n        }\r\n\r\n        // Helper function to get currently selected specs from the page\r\n        function getCurrentSelectedSpecs() {\r\n            const specs = [];\r\n            const specItems = document.querySelectorAll('.spec-item');\r\n            specItems.forEach(item => {\r\n                const param = item.children[0].value;\r\n                if (param) {\r\n                    specs.push(param);\r\n                }\r\n            });\r\n            return specs;\r\n        }\r\n\r\n        // Add a unified kwargs row\r\n        function addKwargRow() {\r\n            const container = document.getElementById('kwargsContainer');\r\n            const kwargsItem = document.createElement('div');\r\n            kwargsItem.className = 'kwargs-item';\r\n\r\n            // 1. Kwarg Type select (Type-wide vs Column-specific)\r\n            const typeSelect = document.createElement('select');\r\n            typeSelect.innerHTML = `\r\n                <option value=\"\">Select type...</option>\r\n                <option value=\"type\">Type-wide</option>\r\n                <option value=\"column\">Column-specific</option>\r\n            `;\r\n\r\n            // 2. Selection dropdown (dtype or column based on type selection)\r\n            const selectionSelect = document.createElement('select');\r\n            selectionSelect.innerHTML = '<option value=\"\">Select...</option>';\r\n            selectionSelect.disabled = true;\r\n\r\n            // 3. Parameter select\r\n            const paramContainer = document.createElement('div');\r\n            paramContainer.style.position = 'relative';\r\n\r\n            const paramSelect = document.createElement('select');\r\n            paramSelect.innerHTML = '<option value=\"\">Select parameter...</option>';\r\n            paramSelect.disabled = true;\r\n\r\n            // Add tooltip div that will show on hover\r\n            const paramTooltip = document.createElement('div');\r\n            paramTooltip.className = 'info-tooltip';\r\n            paramTooltip.style.display = 'none';\r\n            paramContainer.appendChild(paramSelect);\r\n            paramContainer.appendChild(paramTooltip);\r\n\r\n            // 4. Value input\r\n            const valueInput = document.createElement('input');\r\n            valueInput.type = 'text';\r\n            valueInput.placeholder = 'Parameter value';\r\n            valueInput.disabled = true;\r\n\r\n            // 5. Remove button\r\n            const removeBtn = document.createElement('button');\r\n            removeBtn.textContent = '×';\r\n            removeBtn.className = 'remove-btn';\r\n            removeBtn.onclick = () => kwargsItem.remove();\r\n\r\n            // Event listeners for cascading dropdowns\r\n            typeSelect.addEventListener('change', function() {\r\n                const selectedType = this.value;\r\n\r\n                // Reset dependent dropdowns\r\n                selectionSelect.innerHTML = '<option value=\"\">Select...</option>';\r\n                paramSelect.innerHTML = '<option value=\"\">Select parameter...</option>';\r\n                valueInput.value = '';\r\n\r\n                if (selectedType === 'type') {\r\n                    // Populate with dtypes\r\n                    selectionSelect.disabled = false;\r\n                    populateSelectionWithTypes(selectionSelect);\r\n                } else if (selectedType === 'column') {\r\n                    // Populate with columns\r\n                    selectionSelect.disabled = false;\r\n                    populateSelectionWithColumns(selectionSelect);\r\n                } else {\r\n                    selectionSelect.disabled = true;\r\n                    paramSelect.disabled = true;\r\n                    valueInput.disabled = true;\r\n                }\r\n            });\r\n\r\n            selectionSelect.addEventListener('change', function() {\r\n                const kwargType = typeSelect.value;\r\n                const selectedItem = this.value;\r\n\r\n                // Reset dependent dropdowns\r\n                paramSelect.innerHTML = '<option value=\"\">Select parameter...</option>';\r\n                valueInput.value = '';\r\n\r\n                if (selectedItem) {\r\n                    paramSelect.disabled = false;\r\n                    populateParameters(paramSelect, kwargType, selectedItem, this);\r\n                } else {\r\n                    paramSelect.disabled = true;\r\n                    valueInput.disabled = true;\r\n                }\r\n            });\r\n\r\n            paramSelect.addEventListener('change', function() {\r\n                if (this.value) {\r\n                    valueInput.disabled = false;\r\n                    updateValueInputForKwarg(this, valueInput);\r\n\r\n                    // Update tooltip with parameter description\r\n                    const selectedOption = this.selectedOptions[0];\r\n                    if (selectedOption && selectedOption.dataset.kwargProfile) {\r\n                        const kwargProfile = JSON.parse(selectedOption.dataset.kwargProfile);\r\n                        paramTooltip.textContent = `Default: ${kwargProfile.default} | ${kwargProfile.description}`;\r\n                        paramTooltip.style.display = 'block';\r\n                    }\r\n                } else {\r\n                    valueInput.disabled = true;\r\n                    paramTooltip.style.display = 'none';\r\n                    // Remove any extra select elements\r\n                    const existingSelect = valueInput.parentElement.querySelector('select:not([id]):not(.kwargs-item select)');\r\n                    if (existingSelect) {\r\n                        existingSelect.remove();\r\n                    }\r\n                }\r\n            });\r\n\r\n            // Show/hide tooltip on hover\r\n            paramContainer.addEventListener('mouseenter', function() {\r\n                if (paramSelect.value && paramTooltip.textContent) {\r\n                    paramTooltip.style.opacity = '1';\r\n                }\r\n            });\r\n\r\n            paramContainer.addEventListener('mouseleave', function() {\r\n                paramTooltip.style.opacity = '0';\r\n            });\r\n\r\n            kwargsItem.appendChild(typeSelect);\r\n            kwargsItem.appendChild(selectionSelect);\r\n            kwargsItem.appendChild(paramContainer);  // Use container instead of paramSelect directly\r\n            kwargsItem.appendChild(valueInput);\r\n            kwargsItem.appendChild(removeBtn);\r\n\r\n            container.appendChild(kwargsItem);\r\n        }\r\n\r\n        // Update parameter suggestions for column kwargs\r\n        function updateParamSuggestions(paramInput, paramDropdown, kwargs) {\r\n            if (!kwargs || Object.keys(kwargs).length === 0) {\r\n                paramDropdown.style.display = 'none';\r\n                return;\r\n            }\r\n\r\n            paramDropdown.innerHTML = '';\r\n\r\n            Object.keys(kwargs).forEach(paramName => {\r\n                const optionDiv = document.createElement('div');\r\n                optionDiv.className = 'spec-multi-option';\r\n                optionDiv.style.justifyContent = 'flex-start';\r\n\r\n                const label = document.createElement('span');\r\n                label.textContent = `${paramName}: ${kwargs[paramName]}`;\r\n                label.style.cursor = 'pointer';\r\n\r\n                optionDiv.appendChild(label);\r\n\r\n                optionDiv.addEventListener('click', function() {\r\n                    paramInput.value = paramName;\r\n                    paramDropdown.style.display = 'none';\r\n                });\r\n\r\n                paramDropdown.appendChild(optionDiv);\r\n            });\r\n        }\r\n\r\n        // Show parameter suggestions\r\n        function showParamSuggestions(paramInput, paramDropdown, kwargs) {\r\n            if (!kwargs || Object.keys(kwargs).length === 0) {\r\n                return;\r\n            }\r\n\r\n            updateParamSuggestions(paramInput, paramDropdown, kwargs);\r\n            paramDropdown.style.display = 'block';\r\n\r\n            // Hide dropdown when clicking outside\r\n            const hideDropdown = (e) => {\r\n                if (!paramInput.parentElement.contains(e.target)) {\r\n                    paramDropdown.style.display = 'none';\r\n                    document.removeEventListener('click', hideDropdown);\r\n                }\r\n            };\r\n\r\n            setTimeout(() => {\r\n                document.addEventListener('click', hideDropdown);\r\n            }, 0);\r\n        }\r\n\r\n        // Update value input based on selected kwarg profile\r\n        function updateValueInputForKwarg(paramSelect, valueInput) {\r\n            const selectedOption = paramSelect.selectedOptions[0];\r\n            if (!selectedOption || !selectedOption.dataset.kwargProfile) {\r\n                valueInput.type = 'text';\r\n                valueInput.placeholder = 'Parameter value';\r\n                valueInput.value = '';\r\n                // Remove any existing additional select elements (but not the main selects)\r\n                const parentItem = valueInput.closest('.kwargs-item');\r\n                const extraSelects = parentItem.querySelectorAll('select:not(:nth-child(1)):not(:nth-child(2)):not(:nth-child(3))');\r\n                extraSelects.forEach(select => select.remove());\r\n                valueInput.style.display = 'block';\r\n                return;\r\n            }\r\n\r\n            const kwargProfile = JSON.parse(selectedOption.dataset.kwargProfile);\r\n            const dtype = kwargProfile.dtype.toLowerCase();\r\n\r\n            // Remove any existing additional select elements (but keep the main 3 selects)\r\n            const parentItem = valueInput.closest('.kwargs-item');\r\n            const extraSelects = parentItem.querySelectorAll('select:not(:nth-child(1)):not(:nth-child(2)):not(:nth-child(3))');\r\n            extraSelects.forEach(select => select.remove());\r\n\r\n            // If there are options, create a dropdown\r\n            if (kwargProfile.options && kwargProfile.options.length > 0) {\r\n                valueInput.style.display = 'none';\r\n\r\n                const optionsSelect = document.createElement('select');\r\n                optionsSelect.innerHTML = '<option value=\"\">Select option...</option>';\r\n\r\n                kwargProfile.options.forEach(option => {\r\n                    const optionElement = document.createElement('option');\r\n                    optionElement.value = option;\r\n                    optionElement.textContent = option;\r\n                    if (option === kwargProfile.default) {\r\n                        optionElement.selected = true;\r\n                    }\r\n                    optionsSelect.appendChild(optionElement);\r\n                });\r\n\r\n                // Insert after the valueInput (4th position)\r\n                valueInput.parentNode.insertBefore(optionsSelect, valueInput.nextSibling);\r\n                return;\r\n            }\r\n\r\n            // Show the input and configure it based on type\r\n            valueInput.style.display = 'block';\r\n\r\n            if (dtype === 'boolean') {\r\n                // Create true/false dropdown for booleans\r\n                valueInput.style.display = 'none';\r\n\r\n                const boolSelect = document.createElement('select');\r\n                boolSelect.innerHTML = `\r\n                    <option value=\"\">Select...</option>\r\n                    <option value=\"true\" ${kwargProfile.default === true ? 'selected' : ''}>true</option>\r\n                    <option value=\"false\" ${kwargProfile.default === false ? 'selected' : ''}>false</option>\r\n                `;\r\n\r\n                // Insert after the valueInput (4th position)\r\n                valueInput.parentNode.insertBefore(boolSelect, valueInput.nextSibling);\r\n            } else if (dtype === 'int' || dtype === 'integer') {\r\n                valueInput.type = 'number';\r\n                valueInput.step = '1';\r\n                valueInput.value = kwargProfile.default || '';\r\n                valueInput.placeholder = `Default: ${kwargProfile.default}`;\r\n            } else if (dtype === 'float' || dtype === 'number') {\r\n                valueInput.type = 'number';\r\n                valueInput.step = 'any';\r\n                valueInput.value = kwargProfile.default || '';\r\n                valueInput.placeholder = `Default: ${kwargProfile.default}`;\r\n            } else {\r\n                valueInput.type = 'text';\r\n                valueInput.value = kwargProfile.default || '';\r\n                valueInput.placeholder = `Default: ${kwargProfile.default}`;\r\n            }\r\n        }\r\n\r\n        // Perform search\r\n        async function performSearch() {\r\n            const specs = [];\r\n            const specItems = document.querySelectorAll('.spec-item');\r\n\r\n            for (let item of specItems) {\r\n                const param = item.children[0].value;\r\n                const value = item.children[1].querySelector('input').value;\r\n                const weight = parseFloat(item.children[2].value);\r\n\r\n                if (param && value && weight) {\r\n                    // Try to parse value as number if possible\r\n                    let parsedValue = value;\r\n                    if (!isNaN(value) && !isNaN(parseFloat(value))) {\r\n                        parsedValue = parseFloat(value);\r\n                    }\r\n\r\n                    specs.push({\r\n                        name: param,\r\n                        value: parsedValue,\r\n                        weight: weight\r\n                    });\r\n                }\r\n            }\r\n\r\n            if (specs.length === 0) {\r\n                showError('Please add at least one specification');\r\n                return;\r\n            }\r\n\r\n            // Collect kwargs\r\n            const kwargs = {\r\n                col_kwargs: {},\r\n                type_kwargs: {}\r\n            };\r\n\r\n            // Collect kwargs from unified structure\r\n            const kwargItems = document.querySelectorAll('#kwargsContainer .kwargs-item');\r\n            console.log('Found kwargs items:', kwargItems.length);\r\n\r\n            kwargItems.forEach((item, index) => {\r\n                const kwargType = item.children[0].value;      // 'type' or 'column'\r\n                const selection = item.children[1].value;      // dtype or column name\r\n                const paramName = item.children[2].querySelector('select').value;  // parameter name (now in container)\r\n                const valueContainer = item.children[3];       // value input/select\r\n\r\n                console.log(`Kwarg ${index}:`, {\r\n                    kwargType,\r\n                    selection,\r\n                    paramName,\r\n                    valueContainer: valueContainer.tagName\r\n                });\r\n\r\n                if (kwargType && selection && paramName) {\r\n                    // Get value from appropriate input element\r\n                    let paramValue = getValueFromContainer(valueContainer);\r\n                    console.log(`Kwarg ${index} value:`, paramValue);\r\n\r\n                    // Only add if we have a value\r\n                    if (paramValue !== null && paramValue !== '' && paramValue !== undefined) {\r\n                        if (kwargType === 'type') {\r\n                            // Type-wide kwargs\r\n                            if (!kwargs.type_kwargs[selection]) {\r\n                                kwargs.type_kwargs[selection] = {};\r\n                            }\r\n                            kwargs.type_kwargs[selection][paramName] = paramValue;\r\n                        } else if (kwargType === 'column') {\r\n                            // Column-specific kwargs\r\n                            if (!kwargs.col_kwargs[selection]) {\r\n                                kwargs.col_kwargs[selection] = {};\r\n                            }\r\n                            kwargs.col_kwargs[selection][paramName] = paramValue;\r\n                        }\r\n                    }\r\n                }\r\n            });\r\n\r\n            console.log('Final kwargs object:', kwargs);\r\n\r\n            // Only include kwargs if there are any\r\n            const hasKwargs = Object.keys(kwargs.col_kwargs).length > 0 || Object.keys(kwargs.type_kwargs).length > 0;\r\n\r\n            const searchRequest = {\r\n                location: {\r\n                    schema: currentSolution,\r\n                    table: currentSystem\r\n                },\r\n                specs: specs,\r\n                session_id: currentSessionId || null,\r\n                kwargs: hasKwargs ? kwargs : null\r\n            };\r\n\r\n            try {\r\n                document.getElementById('searchBtn').disabled = true;\r\n                document.getElementById('searchBtn').textContent = 'Searching...';\r\n\r\n                const response = await fetch(`${API_BASE}/search`, {\r\n                    method: 'POST',\r\n                    headers: {\r\n                        'Content-Type': 'application/json'\r\n                    },\r\n                    body: JSON.stringify(searchRequest)\r\n                });\r\n\r\n                const data = await response.json();\r\n                currentSessionId = data.session_id;\r\n                // FIXED: Changed from data.results to data.values\r\n                displayResults(data.values);\r\n\r\n            } catch (error) {\r\n                showError('Search failed: ' + error.message);\r\n            } finally {\r\n                document.getElementById('searchBtn').disabled = false;\r\n                document.getElementById('searchBtn').textContent = 'Search Components';\r\n            }\r\n        }\r\n\r\n        // Display search results\r\n        function displayResults(results) {\r\n            const container = document.getElementById('resultsContainer');\r\n\r\n            if (!results || results.length === 0) {\r\n                container.innerHTML = '<p>No results found.</p>';\r\n                document.getElementById('resultsSection').classList.remove('hidden');\r\n                return;\r\n            }\r\n\r\n            // Store all available columns for filtering/sorting\r\n            allResultColumns = Object.keys(results[0]);\r\n            setupResultControls();\r\n\r\n            const table = document.createElement('table');\r\n            table.className = 'results-table';\r\n\r\n            // Create header\r\n            const thead = document.createElement('thead');\r\n            const headerRow = document.createElement('tr');\r\n\r\n            allResultColumns.forEach(key => {\r\n                const th = document.createElement('th');\r\n                th.textContent = key.replace('_', ' ').toUpperCase();\r\n                headerRow.appendChild(th);\r\n            });\r\n\r\n            thead.appendChild(headerRow);\r\n            table.appendChild(thead);\r\n\r\n            // Create body\r\n            const tbody = document.createElement('tbody');\r\n\r\n            results.forEach(result => {\r\n                const row = document.createElement('tr');\r\n\r\n                allResultColumns.forEach(key => {\r\n                    const td = document.createElement('td');\r\n                    let value = result[key];\r\n\r\n                    // Convert boolean values (0/1) to true/false for boolean columns\r\n                    const column = availableColumns.find(col => col.name === key);\r\n                    if (column && column.dtype === 'boolean') {\r\n                        if (value === 1 || value === '1' || value === true) {\r\n                            value = 'true';\r\n                        } else if (value === 0 || value === '0' || value === false) {\r\n                            value = 'false';\r\n                        }\r\n                    }\r\n\r\n                    td.textContent = value !== null && value !== undefined ? value : 'N/A';\r\n\r\n                    // Highlight score columns\r\n                    if (key.toLowerCase().includes('score')) {\r\n                        td.className = 'score-cell';\r\n                    }\r\n\r\n                    row.appendChild(td);\r\n                });\r\n\r\n                tbody.appendChild(row);\r\n            });\r\n\r\n            table.appendChild(tbody);\r\n\r\n            // Create dedicated table container\r\n            const tableContainer = document.createElement('div');\r\n            tableContainer.className = 'results-table-container';\r\n            tableContainer.appendChild(table);\r\n\r\n            container.innerHTML = '';\r\n            container.appendChild(tableContainer);\r\n\r\n            document.getElementById('resultsSection').classList.remove('hidden');\r\n            document.getElementById('resultControls').classList.remove('hidden');\r\n            showSuccess(`Found ${results.length} results (Session ID: ${currentSessionId})`);\r\n        }\r\n\r\n        // Setup result controls (filters, sorting, pagination)\r\n        function setupResultControls() {\r\n            // Store current values before updating\r\n            const currentSortBy = document.getElementById('sortBySelect').value;\r\n            const currentSortAsc = document.getElementById('sortAscCheckbox').checked;\r\n            const currentScoreCoupling = document.getElementById('scoreCouplingCheckbox').checked;\r\n            const currentPage = document.getElementById('pageInput').value;\r\n            const currentPerPage = document.getElementById('perPageSelect').value;\r\n\r\n            // Populate sort dropdown\r\n            const sortSelect = document.getElementById('sortBySelect');\r\n            sortSelect.innerHTML = '';\r\n            allResultColumns.forEach(col => {\r\n                const option = document.createElement('option');\r\n                option.value = col;\r\n                option.textContent = col.replace('_', ' ').toUpperCase();\r\n                // Restore previous selection or default to overall_score\r\n                if (col === currentSortBy || (col === 'overall_score' && !currentSortBy)) {\r\n                    option.selected = true;\r\n                }\r\n                sortSelect.appendChild(option);\r\n            });\r\n\r\n            // Only clear filters and reset controls on initial search (not when applying filters)\r\n            if (!document.getElementById('resultControls').classList.contains('hidden')) {\r\n                // This is a filter application, preserve current settings\r\n                document.getElementById('sortAscCheckbox').checked = currentSortAsc;\r\n                document.getElementById('scoreCouplingCheckbox').checked = currentScoreCoupling;\r\n                document.getElementById('pageInput').value = currentPage;\r\n                document.getElementById('perPageSelect').value = currentPerPage;\r\n            } else {\r\n                // This is a new search, reset everything\r\n                document.getElementById('filtersContainer').innerHTML = '';\r\n                document.getElementById('sortAscCheckbox').checked = false;\r\n                document.getElementById('scoreCouplingCheckbox').checked = false;\r\n                document.getElementById('pageInput').value = '1';\r\n                document.getElementById('perPageSelect').value = '10';\r\n            }\r\n        }\r\n\r\n        // Add a filter row\r\n        function addFilterRow() {\r\n            const container = document.getElementById('filtersContainer');\r\n            const filterItem = document.createElement('div');\r\n            filterItem.className = 'filter-item';\r\n\r\n            // Get already used parameters to prevent duplicates\r\n            const usedParams = Array.from(container.querySelectorAll('.filter-item select')).map(select => select.value).filter(val => val);\r\n\r\n            const paramSelect = document.createElement('select');\r\n            paramSelect.innerHTML = '<option value=\"\">Select parameter...</option>';\r\n            allResultColumns.forEach(col => {\r\n                // Only add if not already used\r\n                if (!usedParams.includes(col)) {\r\n                    const option = document.createElement('option');\r\n                    option.value = col;\r\n                    option.textContent = col.replace('_', ' ').toUpperCase();\r\n                    paramSelect.appendChild(option);\r\n                }\r\n            });\r\n\r\n            // Update other filter dropdowns when this one changes\r\n            paramSelect.addEventListener('change', function() {\r\n                updateFilterDropdowns();\r\n            });\r\n\r\n            const minInput = document.createElement('input');\r\n            minInput.type = 'number';\r\n            minInput.placeholder = 'Min value';\r\n\r\n            const maxInput = document.createElement('input');\r\n            maxInput.type = 'number';\r\n            maxInput.placeholder = 'Max value';\r\n\r\n            const removeBtn = document.createElement('button');\r\n            removeBtn.textContent = '×';\r\n            removeBtn.onclick = () => filterItem.remove();\r\n\r\n            filterItem.appendChild(paramSelect);\r\n\r\n            const controlRow = document.createElement('div');\r\n            controlRow.className = 'filter-controls-row';\r\n\r\n            controlRow.appendChild(minInput);\r\n            controlRow.appendChild(maxInput);\r\n            controlRow.appendChild(removeBtn);\r\n\r\n            filterItem.appendChild(controlRow);\r\n\r\n            container.appendChild(filterItem);\r\n        }\r\n\r\n        // Update filter dropdowns to prevent duplicates\r\n        function updateFilterDropdowns() {\r\n            const container = document.getElementById('filtersContainer');\r\n            const allSelects = container.querySelectorAll('.filter-item select');\r\n            const usedParams = Array.from(allSelects).map(select => select.value).filter(val => val);\r\n\r\n            allSelects.forEach(select => {\r\n                const currentValue = select.value;\r\n                select.innerHTML = '<option value=\"\">Select parameter...</option>';\r\n\r\n                allResultColumns.forEach(col => {\r\n                    // Add option if it's not used elsewhere OR it's the current selection\r\n                    if (!usedParams.includes(col) || col === currentValue) {\r\n                        const option = document.createElement('option');\r\n                        option.value = col;\r\n                        option.textContent = col.replace('_', ' ').toUpperCase();\r\n                        if (col === currentValue) option.selected = true;\r\n                        select.appendChild(option);\r\n                    }\r\n                });\r\n            });\r\n        }\r\n\r\n        // Apply filters, sorting, and pagination\r\n        async function applyFilters() {\r\n            if (!currentSessionId) {\r\n                showError('No search session found. Please perform a search first.');\r\n                return;\r\n            }\r\n\r\n            // Collect filters\r\n            const filters = [];\r\n            const filterItems = document.querySelectorAll('.filter-item');\r\n\r\n            filterItems.forEach(item => {\r\n                const param = item.children[0].value;  // paramSelect still first child\r\n\r\n                const controls = item.querySelector('.filter-controls-row'); // find controls row\r\n                const minVal = controls.children[0].value;  // minInput is first child of controls\r\n                const maxVal = controls.children[1].value;  // maxInput second child\r\n\r\n                if (param && (minVal || maxVal)) {\r\n                    const filter = { name: param };\r\n                    if (minVal) filter.min_val = parseFloat(minVal);\r\n                    if (maxVal) filter.max_val = parseFloat(maxVal);\r\n                    filters.push(filter);\r\n                }\r\n            });\r\n\r\n            // Collect sorting\r\n            const sortBy = document.getElementById('sortBySelect').value;\r\n            const sortAsc = document.getElementById('sortAscCheckbox').checked;\r\n            const scoreCoupling = document.getElementById('scoreCouplingCheckbox').checked;\r\n\r\n            // Collect pagination\r\n            const page = parseInt(document.getElementById('pageInput').value) || 1;\r\n            const perPage = parseInt(document.getElementById('perPageSelect').value) || 10;\r\n\r\n            const retrieveRequest = {\r\n                session_id: currentSessionId,\r\n                filters: filters,\r\n                sort: {\r\n                    by: sortBy,\r\n                    asc: sortAsc,\r\n                    score_coupling: scoreCoupling\r\n                },\r\n                pagination: {\r\n                    page: page,\r\n                    per_page: perPage\r\n                }\r\n            };\r\n\r\n            try {\r\n                document.getElementById('applyFiltersBtn').disabled = true;\r\n                document.getElementById('applyFiltersBtn').textContent = 'Applying...';\r\n\r\n                const response = await fetch(`${API_BASE}/search/${currentSessionId}`, {\r\n                    method: 'POST',\r\n                    headers: {\r\n                        'Content-Type': 'application/json'\r\n                    },\r\n                    body: JSON.stringify(retrieveRequest)\r\n                });\r\n\r\n                const data = await response.json();\r\n                // FIXED: Changed from data.results to data.values\r\n                displayResults(data.values);\r\n\r\n            } catch (error) {\r\n                showError('Failed to apply filters: ' + error.message);\r\n            } finally {\r\n                document.getElementById('applyFiltersBtn').disabled = false;\r\n                document.getElementById('applyFiltersBtn').textContent = 'Apply Filters & Sorting';\r\n            }\r\n        }\r\n\r\n        // Utility functions\r\n        function showError(message) {\r\n            const existing = document.querySelector('.error');\r\n            if (existing) existing.remove();\r\n\r\n            const error = document.createElement('div');\r\n            error.className = 'error';\r\n            error.textContent = message;\r\n            document.querySelector('.content').prepend(error);\r\n\r\n            setTimeout(() => error.remove(), 5000);\r\n        }\r\n\r\n        function showSuccess(message) {\r\n            const existing = document.querySelector('.success');\r\n            if (existing) existing.remove();\r\n\r\n            const success = document.createElement('div');\r\n            success.className = 'success';\r\n            success.textContent = message;\r\n            document.querySelector('.content').prepend(success);\r\n\r\n            setTimeout(() => success.remove(), 5000);\r\n        }\r\n\r\n        // Event listeners\r\n        document.getElementById('solutionSelect').addEventListener('change', function(e) {\r\n            currentSolution = e.target.value;\r\n            if (currentSolution) {\r\n                loadSystems(currentSolution);\r\n            } else {\r\n                resetSystemAndBelow();\r\n            }\r\n        });\r\n\r\n        document.getElementById('systemSelect').addEventListener('change', function(e) {\r\n            currentSystem = e.target.value;\r\n            if (currentSystem) {\r\n                loadParameters(currentSolution, currentSystem);\r\n            } else {\r\n                resetResultsAndBelow();\r\n            }\r\n        });\r\n\r\n        document.getElementById('addSpecBtn').addEventListener('click', addSpecificationRow);\r\n        document.getElementById('addKwargBtn').addEventListener('click', addKwargRow);\r\n        document.getElementById('searchBtn').addEventListener('click', performSearch);\r\n        document.getElementById('addFilterBtn').addEventListener('click', addFilterRow);\r\n        document.getElementById('applyFiltersBtn').addEventListener('click', applyFilters);\r\n\r\n        // Initialize the app\r\n        init();\r\n    </script>\r\n</body>\r\n</html>
