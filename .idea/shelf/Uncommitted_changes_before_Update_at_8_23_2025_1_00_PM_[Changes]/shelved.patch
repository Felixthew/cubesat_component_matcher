         color: #16a34a;\r\n            padding: 1rem;\r\n            border-radius: 8px;\r\n            margin: 1rem 0;\r\n        }\r\n\r\n        .hidden {\r\n            display: none;\r\n        }\r\n\r\n        .grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\r\n            gap: 1rem;\r\n        }\r\n\r\n        .filter-item {\r\n            margin-bottom: 1rem;\r\n        }\r\n\r\n        .filter-controls-row {\r\n            display: flex;\r\n            gap: 0.5rem;\r\n            margin-top: 0.5rem;\r\n            align-items: center;\r\n        }\r\n\r\n        .filter-controls-row input[type=\"number\"] {\r\n            flex: 1;\r\n        }\r\n\r\n        .filter-controls-row button {\r\n            width: auto;\r\n            padding: 0.5rem;\r\n            background: #ef4444;\r\n            font-size: 0.8rem;\r\n            color: white;\r\n            border: none;\r\n            border-radius: 4px;\r\n            cursor: pointer;\r\n        }\r\n\r\n        .kwargs-item {\r\n            display: grid;\r\n            grid-template-columns: 2fr 2fr 1fr auto;\r\n            gap: 0.5rem;\r\n            margin-bottom: 0.5rem;\r\n            align-items: end;\r\n        }\r\n\r\n        .kwargs-container {\r\n            border: 1px solid #d1d5db;\r\n            border-radius: 8px;\r\n            padding: 1rem;\r\n            background: white;\r\n            margin-bottom: 1rem;\r\n        }\r\n\r\n        @media (max-width: 768px) {\r\n            .spec-item {\r\n                grid-template-columns: 1fr;\r\n            }\r\n\r\n            .header h1 {\r\n                font-size: 2rem;\r\n            }\r\n\r\n            .content {\r\n                padding: 1rem;\r\n            }\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div class=\"container\">\r\n        <div class=\"header\">\r\n            <h1>Component Matcher</h1>\r\n            <p>Find and score components based on your specifications</p>\r\n        </div>\r\n\r\n        <div class=\"content\">\r\n            <!-- Step 1: Select Solution -->\r\n            <div class=\"section\">\r\n                <h2>1. Select Solution Type</h2>\r\n                <div class=\"form-group\">\r\n                    <label for=\"solutionSelect\">Choose a solution category:</label>\r\n                    <select id=\"solutionSelect\">\r\n                        <option value=\"\">Loading solutions...</option>\r\n                    </select>\r\n                </div>\r\n            </div>\r\n\r\n            <!-- Step 2: Select System -->\r\n            <div class=\"section hidden\" id=\"systemSection\">\r\n                <h2>2. Select System Type</h2>\r\n                <div class=\"loading-indicator\" id=\"systemLoadingIndicator\">Loading systems...</div>\r\n                <div class=\"form-group\">\r\n                    <label for=\"systemSelect\">Choose a system:</label>\r\n                    <select id=\"systemSelect\">\r\n                        <option value=\"\">Select a solution first</option>\r\n                    </select>\r\n                </div>\r\n            </div>\r\n\r\n            <!-- Step 3: Configure Specifications -->\r\n            <div class=\"section hidden\" id=\"specsSection\">\r\n                <h2>3. Configure Specifications</h2>\r\n                <div class=\"loading-indicator\" id=\"specsLoadingIndicator\">Loading parameters...</div>\r\n                <div class=\"specs-container\">\r\n                    <div id=\"specsContainer\">\r\n                        <!-- Specs will be added here dynamically -->\r\n                    </div>\r\n                    <button type=\"button\" class=\"add-btn\" id=\"addSpecBtn\">Add Specification</button>\r\n                </div>\r\n                <button type=\"button\" id=\"searchBtn\" style=\"margin-top: 1rem;\">Search Components</button>\r\n            </div>\r\n\r\n            <!-- Step 4: Configure Scoring Parameters (Optional) -->\r\n            <div class=\"section hidden\" id=\"kwargsSection\">\r\n                <h2>4. Configure Scoring Parameters (Optional)</h2>\r\n                <div class=\"grid\" style=\"margin-bottom: 1rem;\">\r\n                    <div>\r\n                        <h3>Global Type Parameters</h3>\r\n                        <div id=\"typeKwargsContainer\">\r\n                            <!-- Type-wide kwargs will be added here -->\r\n                        </div>\r\n                        <button type=\"button\" class=\"add-btn\" id=\"addTypeKwargBtn\">Add Type Parameter</button>\r\n                    </div>\r\n                    <div>\r\n                        <h3>Column-Specific Parameters</h3>\r\n                        <div id=\"colKwargsContainer\">\r\n                            <!-- Column-specific kwargs will be added here -->\r\n                        </div>\r\n                        <button type=\"button\" class=\"add-btn\" id=\"addColKwargBtn\">Add Column Parameter</button>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <!-- Results Section -->\r\n            <div class=\"section hidden\" id=\"resultsSection\">\r\n                <h2>Results</h2>\r\n\r\n                <!-- Filters and Sorting Controls -->\r\n                <div class=\"hidden\" id=\"resultControls\">\r\n                    <div class=\"grid\" style=\"margin-bottom: 1rem;\">\r\n                        <div>\r\n                            <h3>Filter Results</h3>\r\n                            <div id=\"filtersContainer\">\r\n                                <!-- Filters will be added here -->\r\n                            </div>\r\n                            <button type=\"button\" class=\"add-btn\" id=\"addFilterBtn\">Add Filter</button>\r\n                        </div>\r\n\r\n                        <div>\r\n                            <h3>Sort Results</h3>\r\n                            <div class=\"form-group\">\r\n                                <label for=\"sortBySelect\">Sort by:</label>\r\n                                <select id=\"sortBySelect\">\r\n                                    <option value=\"overall_score\">Overall Score</option>\r\n                                </select>\r\n                            </div>\r\n                            <div class=\"form-group\" style=\"display: flex; align-items: center; gap: 0.3rem; white-space: nowrap;\">\r\n                                <label for=\"sortAscCheckbox\" style=\"margin: 0;\">Sort ascending</label>\r\n                                <input type=\"checkbox\" id=\"sortAscCheckbox\">\r\n                            </div>\r\n                            <div class=\"form-group\" style=\"display: flex; align-items: center; gap: 0.3rem; white-space: nowrap;\">\r\n                                <label for=\"scoreCouplingCheckbox\" style=\"margin: 0;\">Score coupling</label>\r\n                                <input type=\"checkbox\" id=\"scoreCouplingCheckbox\">\r\n                            </div>\r\n                        </div>\r\n\r\n                        <div>\r\n                            <h3>Pagination</h3>\r\n                            <div class=\"form-group\">\r\n                                <label for=\"pageInput\">Page:</label>\r\n                                <input type=\"number\" id=\"pageInput\" value=\"1\" min=\"1\">\r\n                            </div>\r\n                            <div class=\"form-group\">\r\n                                <label for=\"perPageSelect\">Results per page:</label>\r\n                                <select id=\"perPageSelect\">\r\n                                    <option value=\"10\">10</option>\r\n                                    <option value=\"25\">25</option>\r\n                                    <option value=\"50\">50</option>\r\n                                    <option value=\"100\">100</option>\r\n                                </select>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <button type=\"button\" id=\"applyFiltersBtn\">Apply Filters & Sorting</button>\r\n                </div>\r\n\r\n                <div class=\"results-container\" id=\"resultsContainer\">\r\n                    <!-- Results will be displayed here -->\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <script>\r\n        const API_BASE = 'http://localhost:8000'; // Change this to your API URL\r\n\r\n        let currentSolution = '';\r\n        let currentSystem = '';\r\n        let availableColumns = [];\r\n        let currentSessionId = '';\r\n        let allResultColumns = [];\r\n        let availableDataTypes = new Set();\r\n\r\n        // Initialize the application\r\n        async function init() {\r\n            await loadSolutions();\r\n        }\r\n\r\n        // Load available solutions\r\n        async function loadSolutions() {\r\n            try {\r\n                const response = await fetch(`${API_BASE}/options`);\r\n                const data = await response.json();\r\n\r\n                const select = document.getElementById('solutionSelect');\r\n                select.innerHTML = '<option value=\"\">Select a solution...</option>';\r\n\r\n                data.schemas.forEach(schema => {\r\n                    // Filter out metadata and pg_toast schemas\r\n                    if (schema !== 'metadata' && schema !== 'pg_toast') {\r\n                        const option = document.createElement('option');\r\n                        option.value = schema;\r\n                        option.textContent = schema;\r\n                        select.appendChild(option);\r\n                    }\r\n                });\r\n            } catch (error) {\r\n                showError('Failed to load solutions: ' + error.message);\r\n            }\r\n        }\r\n\r\n        // Load systems for selected solution\r\n        async function loadSystems(solution) {\r\n            try {\r\n                // Reset subsequent sections when solution changes\r\n                resetSystemAndBelow();\r\n\r\n                // Show loading indicator\r\n                document.getElementById('systemSection').classList.remove('hidden');\r\n                document.getElementById('systemLoadingIndicator').classList.add('show');\r\n\r\n                const response = await fetch(`${API_BASE}/options/${solution}`);\r\n                const data = await response.json();\r\n\r\n                const select = document.getElementById('systemSelect');\r\n                select.innerHTML = '<option value=\"\">Select a system...</option>';\r\n\r\n                data.tables.forEach(table => {\r\n                    const option = document.createElement('option');\r\n                    option.value = table;\r\n                    option.textContent = table;\r\n                    select.appendChild(option);\r\n                });\r\n\r\n                // Hide loading indicator\r\n                document.getElementById('systemLoadingIndicator').classList.remove('show');\r\n\r\n            } catch (error) {\r\n                document.getElementById('systemLoadingIndicator').classList.remove('show');\r\n                showError('Failed to load systems: ' + error.message);\r\n            }\r\n        }\r\n\r\n        // Reset system selection and everything below it\r\n        function resetSystemAndBelow() {\r\n            document.getElementById('systemSelect').innerHTML = '<option value=\"\">Select a system...</option>';\r\n            document.getElementById('specsSection').classList.add('hidden');\r\n            document.getElementById('kwargsSection').classList.add('hidden');\r\n            resetResultsAndBelow();\r\n            currentSystem = '';\r\n            availableColumns = [];\r\n            availableDataTypes.clear();\r\n        }\r\n\r\n        // Load parameters for selected system\r\n        async function loadParameters(solution, system) {\r\n            try {\r\n                // Reset everything below this level\r\n                resetResultsAndBelow();\r\n\r\n                // Show loading indicator\r\n                document.getElementById('specsSection').classList.remove('hidden');\r\n                document.getElementById('specsLoadingIndicator').classList.add('show');\r\n\r\n                const response = await fetch(`${API_BASE}/options/${solution}/${system}`);\r\n                const data = await response.json();\r\n\r\n                availableColumns = data.columns;\r\n\r\n                // Collect unique data types\r\n                availableDataTypes.clear();\r\n                data.columns.forEach(col => {\r\n                    availableDataTypes.add(col.dtype);\r\n                });\r\n\r\n                setupSpecsSection();\r\n                setupKwargsSection();\r\n\r\n                // Hide loading indicator\r\n                document.getElementById('specsLoadingIndicator').classList.remove('show');\r\n\r\n            } catch (error) {\r\n                document.getElementById('specsLoadingIndicator').classList.remove('show');\r\n                showError('Failed to load parameters: ' + error.message);\r\n            }\r\n        }\r\n\r\n        // Reset results and everything below\r\n        function resetResultsAndBelow() {\r\n            document.getElementById('resultsSection').classList.add('hidden');\r\n            document.getElementById('resultControls').classList.add('hidden');\r\n            currentSessionId = '';\r\n            allResultColumns = [];\r\n        }\r\n\r\n        // Setup specifications section\r\n        function setupSpecsSection() {\r\n            // Reset results when specs change\r\n            resetResultsAndBelow();\r\n\r\n            const container = document.getElementById('specsContainer');\r\n            container.innerHTML = '';\r\n            addSpecificationRow();\r\n        }\r\n\r\n        // Setup kwargs section\r\n        function setupKwargsSection() {\r\n            document.getElementById('kwargsSection').classList.remove('hidden');\r\n\r\n            const typeContainer = document.getElementById('typeKwargsContainer');\r\n            const colContainer = document.getElementById('colKwargsContainer');\r\n\r\n            typeContainer.innerHTML = '';\r\n            colContainer.innerHTML = '';\r\n        }\r\n\r\n        // Add a specification row\r\n        function addSpecificationRow() {\r\n            const container = document.getElementById('specsContainer');\r\n            const specItem = document.createElement('div');\r\n            specItem.className = 'spec-item';\r\n\r\n            // Get already used parameters to prevent duplicates\r\n            const usedParams = Array.from(container.querySelectorAll('.spec-item select')).map(select => select.value).filter(val => val);\r\n\r\n            const paramSelect = document.createElement('select');\r\n            paramSelect.innerHTML = '<option value=\"\">Select parameter...</option>';\r\n            availableColumns.forEach(col => {\r\n                // Only add if not already used\r\n                if (!usedParams.includes(col.name)) {\r\n                    const option = document.createElement('option');\r\n                    option.value = col.name;\r\n                    option.textContent = `${col.name} (${col.dtype})`;\r\n                    paramSelect.appendChild(option);\r\n                }\r\n            });\r\n\r\n            const valueContainer = document.createElement('div');\r\n            valueContainer.className = 'spec-value-container';\r\n\r\n            const valueInput = document.createElement('input');\r\n            valueInput.type = 'text';\r\n            valueInput.placeholder = 'Value';\r\n            valueInput.className = 'spec-search-input';\r\n            valueInput.readOnly = true; // Make it read-only for multi-select\r\n\r\n            const multiSelectDiv = document.createElement('div');\r\n            multiSelectDiv.className = 'spec-multi-select';\r\n\r\n            const selectedItemsDiv = document.createElement('div');\r\n            selectedItemsDiv.className = 'spec-selected-items';\r\n\r\n            valueContainer.appendChild(valueInput);\r\n            valueContainer.appendChild(selectedItemsDiv);\r\n            valueContainer.appendChild(multiSelectDiv);\r\n\r\n            // Setup search functionality\r\n            let currentOptions = [];\r\n            let selectedValues = [];\r\n            let isMultiSelect = false;\r\n\r\n            // Update options when parameter changes\r\n            paramSelect.addEventListener('change', function() {\r\n                const selectedParam = availableColumns.find(col => col.name === this.value);\r\n                currentOptions = selectedParam?.options || [];\r\n                selectedValues = [];\r\n\r\n                // Check parameter type for input mode\r\n                if (selectedParam && selectedParam.dtype === 'boolean') {\r\n                    // Boolean parameters get a true/false dropdown\r\n                    isMultiSelect = false;\r\n                    currentOptions = ['true', 'false'];\r\n                    valueInput.placeholder = 'Click to select true/false';\r\n                    valueInput.readOnly = true;\r\n                } else if (selectedParam && selectedParam.dtype === 'list' && currentOptions.length > 0) {\r\n                    // List parameters get multi-select checkboxes\r\n                    isMultiSelect = true;\r\n                    valueInput.placeholder = 'Click to select options';\r\n                    valueInput.readOnly = true;\r\n                } else if (currentOptions.length > 0) {\r\n                    // String parameters with options get single-select dropdown\r\n                    isMultiSelect = false;\r\n                    valueInput.placeholder = 'Value (click to see options)';\r\n                    valueInput.readOnly = false;\r\n                } else {\r\n                    // Parameters without options get regular text input\r\n                    isMultiSelect = false;\r\n                    valueInput.placeholder = 'Value';\r\n                    valueInput.readOnly = false;\r\n                }\r\n\r\n                valueInput.value = '';\r\n                multiSelectDiv.style.display = 'none';\r\n                updateSelectedItems();\r\n\r\n                // Update other dropdowns to remove this selection\r\n                updateParameterDropdowns();\r\n            });\r\n\r\n            // Show multi-select when clicking on input (for multi-select mode)\r\n            valueInput.addEventListener('click', function() {\r\n                const selectedParam = availableColumns.find(col => col.name === paramSelect.value);\r\n\r\n                if (selectedParam && selectedParam.dtype === 'boolean') {\r\n                    // Show true/false dropdown for boolean parameters\r\n                    showBooleanSelect();\r\n                } else if (isMultiSelect && currentOptions.length > 0) {\r\n                    showMultiSelect();\r\n                } else if (!isMultiSelect && currentOptions.length > 0) {\r\n                    showSingleSelect();\r\n                }\r\n            });\r\n\r\n            // Allow typing for single-value inputs\r\n            valueInput.addEventListener('input', function() {\r\n                if (!isMultiSelect && currentOptions.length > 0) {\r\n                    showSingleSelect(this.value);\r\n                }\r\n            });\r\n\r\n            function showSingleSelect(query = '') {\r\n                multiSelectDiv.innerHTML = '';\r\n\r\n                if (currentOptions.length === 0) {\r\n                    multiSelectDiv.style.display = 'none';\r\n                    return;\r\n                }\r\n\r\n                const filteredOptions = query === '' ?\r\n                    currentOptions :\r\n                    currentOptions.filter(option =>\r\n                        option.toString().toLowerCase().includes(query.toLowerCase())\r\n                    );\r\n\r\n                if (filteredOptions.length === 0) {\r\n                    multiSelectDiv.style.display = 'none';\r\n                    return;\r\n                }\r\n\r\n                // Sort filtered options alphabetically\r\n                const sortedOptions = filteredOptions.sort((a, b) =>\r\n                    a.toString().localeCompare(b.toString())\r\n                );\r\n\r\n                sortedOptions.forEach(option => {\r\n                    const optionDiv = document.createElement('div');\r\n                    optionDiv.className = 'spec-multi-option';\r\n                    optionDiv.style.justifyContent = 'flex-start';\r\n\r\n                    const label = document.createElement('span');\r\n                    label.textContent = option;\r\n                    label.style.cursor = 'pointer';\r\n\r\n                    optionDiv.appendChild(label);\r\n\r\n                    optionDiv.addEventListener('click', function() {\r\n                        valueInput.value = option;\r\n                        multiSelectDiv.style.display = 'none';\r\n                    });\r\n\r\n                    multiSelectDiv.appendChild(optionDiv);\r\n                });\r\n\r\n                multiSelectDiv.style.display = 'block';\r\n            }\r\n\r\n            function showBooleanSelect() {\r\n                multiSelectDiv.innerHTML = '';\r\n\r\n                ['false', 'true'].forEach(option => {\r\n                    const optionDiv = document.createElement('div');\r\n                    optionDiv.className = 'spec-multi-option';\r\n                    optionDiv.style.justifyContent = 'flex-start';\r\n\r\n                    const label = document.createElement('span');\r\n                    label.textContent = option;\r\n                    label.style.cursor = 'pointer';\r\n\r\n                    optionDiv.appendChild(label);\r\n\r\n                    optionDiv.addEventListener('click', function() {\r\n                        valueInput.value = option;\r\n                        multiSelectDiv.style.display = 'none';\r\n                    });\r\n\r\n                    multiSelectDiv.appendChild(optionDiv);\r\n                });\r\n\r\n                multiSelectDiv.style.display = 'block';\r\n            }\r\n\r\n            function showMultiSelect() {\r\n                multiSelectDiv.innerHTML = '';\r\n\r\n                // Sort options alphabetically\r\n                const sortedOptions = [...currentOptions].sort((a, b) =>\r\n                    a.toString().localeCompare(b.toString())\r\n                );\r\n\r\n                sortedOptions.forEach(option => {\r\n                    const optionDiv = document.createElement('div');\r\n                    optionDiv.className = 'spec-multi-option';\r\n\r\n                    const checkbox = document.createElement('input');\r\n                    checkbox.type = 'checkbox';\r\n                    checkbox.checked = selectedValues.includes(option);\r\n\r\n                    const label = document.createElement('span');\r\n                    label.textContent = option;\r\n\r\n                    optionDiv.appendChild(checkbox);\r\n                    optionDiv.appendChild(label);\r\n\r\n                    optionDiv.addEventListener('click', function(e) {\r\n                        if (e.target.type !== 'checkbox') {\r\n                            checkbox.checked = !checkbox.checked;\r\n                        }\r\n                        toggleOption(option, checkbox.checked);\r\n                    });\r\n\r\n                    checkbox.addEventListener('change', function() {\r\n                        toggleOption(option, this.checked);\r\n                    });\r\n\r\n                    multiSelectDiv.appendChild(optionDiv);\r\n                });\r\n\r\n                multiSelectDiv.style.display = 'block';\r\n            }\r\n\r\n            function toggleOption(option, isSelected) {\r\n                if (isSelected) {\r\n                    if (!selectedValues.includes(option)) {\r\n                        selectedValues.push(option);\r\n                    }\r\n                } else {\r\n                    selectedValues = selectedValues.filter(val => val !== option);\r\n                }\r\n                updateSelectedItems();\r\n                updateInputValue();\r\n            }\r\n\r\n            function updateSelectedItems() {\r\n                // Hidden for now to clean up the interface\r\n                selectedItemsDiv.innerHTML = '';\r\n            }\r\n\r\n            function updateInputValue() {\r\n                if (isMultiSelect) {\r\n                    valueInput.value = selectedValues.join(', ');\r\n                }\r\n            }\r\n\r\n            // Hide multi-select when clicking outside\r\n            document.addEventListener('click', function(e) {\r\n                if (!valueContainer.contains(e.target)) {\r\n                    multiSelectDiv.style.display = 'none';\r\n                }\r\n            });\r\n\r\n            const weightInput = document.createElement('input');\r\n            weightInput.type = 'number';\r\n            weightInput.placeholder = 'Weight';\r\n            weightInput.value = '1';\r\n            weightInput.step = '0.1';\r\n            weightInput.min = '0.1';\r\n\r\n            const removeBtn = document.createElement('button');\r\n            removeBtn.textContent = '×';\r\n            removeBtn.className = 'remove-btn';\r\n            removeBtn.onclick = () => specItem.remove();\r\n\r\n            specItem.appendChild(paramSelect);\r\n            specItem.appendChild(valueContainer);\r\n            specItem.appendChild(weightInput);\r\n            specItem.appendChild(removeBtn);\r\n\r\n            container.appendChild(specItem);\r\n        }\r\n\r\n        // Update parameter dropdowns to prevent duplicates\r\n        function updateParameterDropdowns() {\r\n            const container = document.getElementById('specsContainer');\r\n            const allSelects = container.querySelectorAll('.spec-item select');\r\n            const usedParams = Array.from(allSelects).map(select => select.value).filter(val => val);\r\n\r\n            allSelects.forEach(select => {\r\n                const currentValue = select.value;\r\n                select.innerHTML = '<option value=\"\">Select parameter...</option>';\r\n\r\n                availableColumns.forEach(col => {\r\n                    // Add option if it's not used elsewhere OR it's the current selection\r\n                    if (!usedParams.includes(col.name) || col.name === currentValue) {\r\n                        const option = document.createElement('option');\r\n                        option.value = col.name;\r\n                        option.textContent = `${col.name} (${col.dtype})`;\r\n                        if (col.name === currentValue) option.selected = true;\r\n                        select.appendChild(option);\r\n                    }\r\n                });\r\n            });\r\n        }\r\n\r\n        // Add a type-wide kwargs row\r\n        function addTypeKwargRow() {\r\n            const container = document.getElementById('typeKwargsContainer');\r\n            const kwargsItem = document.createElement('div');\r\n            kwargsItem.className = 'kwargs-item';\r\n\r\n            // Data type select\r\n            const typeSelect = document.createElement('select');\r\n            typeSelect.innerHTML = '<option value=\"\">Select data type...</option>';\r\n            Array.from(availableDataTypes).sort().forEach(dtype => {\r\n                const option = document.createElement('option');\r\n                option.value = dtype;\r\n                option.textContent = dtype;\r\n                typeSelect.appendChild(option);\r\n            });\r\n\r\n            // Parameter name input\r\n            const paramInput = document.createElement('input');\r\n            paramInput.type = 'text';\r\n            paramInput.placeholder = 'Parameter name';\r\n\r\n            // Parameter value input\r\n            const valueInput = document.createElement('input');\r\n            valueInput.type = 'text';\r\n            valueInput.placeholder = 'Parameter value';\r\n\r\n            // Remove button\r\n            const removeBtn = document.createElement('button');\r\n            removeBtn.textContent = '×';\r\n            removeBtn.className = 'remove-btn';\r\n            removeBtn.onclick = () => kwargsItem.remove();\r\n\r\n            kwargsItem.appendChild(typeSelect);\r\n            kwargsItem.appendChild(paramInput);\r\n            kwargsItem.appendChild(valueInput);\r\n            kwargsItem.appendChild(removeBtn);\r\n\r\n            container.appendChild(kwargsItem);\r\n        }\r\n\r\n        // Add a column-specific kwargs row\r\n        function addColKwargRow() {\r\n            const container = document.getElementById('colKwargsContainer');\r\n            const kwargsItem = document.createElement('div');\r\n            kwargsItem.className = 'kwargs-item';\r\n\r\n            // Column select\r\n            const colSelect = document.createElement('select');\r\n            colSelect.innerHTML = '<option value=\"\">Select column...</option>';\r\n            availableColumns.forEach(col => {\r\n                const option = document.createElement('option');\r\n                option.value = col.name;\r\n                option.textContent = `${col.name} (${col.dtype})`;\r\n                colSelect.appendChild(option);\r\n            });\r\n\r\n            // Parameter name input with dropdown if kwargs available\r\n            const paramContainer = document.createElement('div');\r\n            paramContainer.style.position = 'relative';\r\n\r\n            const paramInput = document.createElement('input');\r\n            paramInput.type = 'text';\r\n            paramInput.placeholder = 'Parameter name';\r\n\r\n            const paramDropdown = document.createElement('div');\r\n            paramDropdown.className = 'spec-multi-select';\r\n            paramDropdown.style.display = 'none';\r\n\r\n            paramContainer.appendChild(paramInput);\r\n            paramContainer.appendChild(paramDropdown);\r\n\r\n            // Update parameter suggestions when column changes\r\n            colSelect.addEventListener('change', function() {\r\n                const selectedCol = availableColumns.find(col => col.name === this.value);\r\n                if (selectedCol && selectedCol.kwargs) {\r\n                    // Show available kwargs for this column\r\n                    updateParamSuggestions(paramInput, paramDropdown, selectedCol.kwargs);\r\n                } else {\r\n                    paramDropdown.style.display = 'none';\r\n                }\r\n            });\r\n\r\n            // Show suggestions when clicking on parameter input\r\n            paramInput.addEventListener('click', function() {\r\n                const selectedCol = availableColumns.find(col => col.name === colSelect.value);\r\n                if (selectedCol && selectedCol.kwargs) {\r\n                    showParamSuggestions(paramInput, paramDropdown, selectedCol.kwargs);\r\n                }\r\n            });\r\n\r\n            // Parameter value input\r\n            const valueInput = document.createElement('input');\r\n            valueInput.type = 'text';\r\n            valueInput.placeholder = 'Parameter value';\r\n\r\n            // Remove button\r\n            const removeBtn = document.createElement('button');\r\n            removeBtn.textContent = '×';\r\n            removeBtn.className = 'remove-btn';\r\n            removeBtn.onclick = () => kwargsItem.remove();\r\n\r\n            kwargsItem.appendChild(colSelect);\r\n            kwargsItem.appendChild(paramContainer);\r\n            kwargsItem.appendChild(valueInput);\r\n            kwargsItem.appendChild(removeBtn);\r\n\r\n            container.appendChild(kwargsItem);\r\n        }\r\n\r\n        // Update parameter suggestions for column kwargs\r\n        function updateParamSuggestions(paramInput, paramDropdown, kwargs) {\r\n            if (!kwargs || Object.keys(kwargs).length === 0) {\r\n                paramDropdown.style.display = 'none';\r\n                return;\r\n            }\r\n\r\n            paramDropdown.innerHTML = '';\r\n\r\n            Object.keys(kwargs).forEach(paramName => {\r\n                const optionDiv = document.createElement('div');\r\n                optionDiv.className = 'spec-multi-option';\r\n                optionDiv.style.justifyContent = 'flex-start';\r\n\r\n                const label = document.createElement('span');\r\n                label.textContent = `${paramName}: ${kwargs[paramName]}`;\r\n                label.style.cursor = 'pointer';\r\n\r\n                optionDiv.appendChild(label);\r\n\r\n                optionDiv.addEventListener('click', function() {\r\n                    paramInput.value = paramName;\r\n                    paramDropdown.style.display = 'none';\r\n                });\r\n\r\n                paramDropdown.appendChild(optionDiv);\r\n            });\r\n        }\r\n\r\n        // Show parameter suggestions\r\n        function showParamSuggestions(paramInput, paramDropdown, kwargs) {\r\n            if (!kwargs || Object.keys(kwargs).length === 0) {\r\n                return;\r\n            }\r\n\r\n            updateParamSuggestions(paramInput, paramDropdown, kwargs);\r\n            paramDropdown.style.display = 'block';\r\n\r\n            // Hide dropdown when clicking outside\r\n            const hideDropdown = (e) => {\r\n                if (!paramInput.parentElement.contains(e.target)) {\r\n                    paramDropdown.style.display = 'none';\r\n                    document.removeEventListener('click', hideDropdown);\r\n                }\r\n            };\r\n\r\n            setTimeout(() => {\r\n                document.addEventListener('click', hideDropdown);\r\n            }, 0);\r\n        }\r\n\r\n        // Perform search\r\n        async function performSearch() {\r\n            const specs = [];\r\n            const specItems = document.querySelectorAll('.spec-item');\r\n\r\n            for (let item of specItems) {\r\n                const param = item.children[0].value;\r\n                const value = item.children[1].querySelector('input').value;\r\n                const weight = parseFloat(item.children[2].value);\r\n\r\n                if (param && value && weight) {\r\n                    // Try to parse value as number if possible\r\n                    let parsedValue = value;\r\n                    if (!isNaN(value) && !isNaN(parseFloat(value))) {\r\n                        parsedValue = parseFloat(value);\r\n                    }\r\n\r\n                    specs.push({\r\n                        name: param,\r\n                        value: parsedValue,\r\n                        weight: weight\r\n                    });\r\n                }\r\n            }\r\n\r\n            if (specs.length === 0) {\r\n                showError('Please add at least one specification');\r\n                return;\r\n            }\r\n\r\n            // Collect kwargs\r\n            const kwargs = {\r\n                col_kwargs: {},\r\n                type_kwargs: {}\r\n            };\r\n\r\n            // Collect type-wide kwargs\r\n            const typeKwargItems = document.querySelectorAll('#typeKwargsContainer .kwargs-item');\r\n            typeKwargItems.forEach(item => {\r\n                const dataType = item.children[0].value;\r\n                const paramName = item.children[1].value;\r\n                const paramValue = item.children[2].value;\r\n\r\n                if (dataType && paramName && paramValue) {\r\n                    if (!kwargs.type_kwargs[dataType]) {\r\n                        kwargs.type_kwargs[dataType] = {};\r\n                    }\r\n\r\n                    // Try to parse value as number if possible\r\n                    let parsedValue = paramValue;\r\n                    if (!isNaN(paramValue) && !isNaN(parseFloat(paramValue))) {\r\n                        parsedValue = parseFloat(paramValue);\r\n                    } else if (paramValue.toLowerCase() === 'true') {\r\n                        parsedValue = true;\r\n                    } else if (paramValue.toLowerCase() === 'false') {\r\n                        parsedValue = false;\r\n                    }\r\n\r\n                    kwargs.type_kwargs[dataType][paramName] = parsedValue;\r\n                }\r\n            });\r\n\r\n            // Collect column-specific kwargs\r\n            const colKwargItems = document.querySelectorAll('#colKwargsContainer .kwargs-item');\r\n            colKwargItems.forEach(item => {\r\n                const colName = item.children[0].value;\r\n                const paramName = item.children[1].querySelector('input').value;\r\n                const paramValue = item.children[2].value;\r\n\r\n                if (colName && paramName && paramValue) {\r\n                    if (!kwargs.col_kwargs[colName]) {\r\n                        kwargs.col_kwargs[colName] = {};\r\n                    }\r\n\r\n                    // Try to parse value as number if possible\r\n                    let parsedValue = paramValue;\r\n                    if (!isNaN(paramValue) && !isNaN(parseFloat(paramValue))) {\r\n                        parsedValue = parseFloat(paramValue);\r\n                    } else if (paramValue.toLowerCase() === 'true') {\r\n                        parsedValue = true;\r\n                    } else if (paramValue.toLowerCase() === 'false') {\r\n                        parsedValue = false;\r\n                    }\r\n\r\n                    kwargs.col_kwargs[colName][paramName] = parsedValue;\r\n                }\r\n            });\r\n\r\n            // Only include kwargs if there are any\r\n            const hasKwargs = Object.keys(kwargs.col_kwargs).length > 0 || Object.keys(kwargs.type_kwargs).length > 0;\r\n\r\n            const searchRequest = {\r\n                location: {\r\n                    schema: currentSolution,\r\n                    table: currentSystem\r\n                },\r\n                specs: specs,\r\n                session_id: currentSessionId || null,\r\n                kwargs: hasKwargs ? kwargs : null\r\n            };\r\n\r\n            try {\r\n                document.getElementById('searchBtn').disabled = true;\r\n                document.getElementById('searchBtn').textContent = 'Searching...';\r\n\r\n                const response = await fetch(`${API_BASE}/search`, {\r\n                    method: 'POST',\r\n                    headers: {\r\n                        'Content-Type': 'application/json'\r\n                    },\r\n                    body: JSON.stringify(searchRequest)\r\n                });\r\n\r\n                const data = await response.json();\r\n                currentSessionId = data.session_id;\r\n                // FIXED: Changed from data.results to data.values\r\n                displayResults(data.values);\r\n\r\n            } catch (error) {\r\n                showError('Search failed: ' + error.message);\r\n            } finally {\r\n                document.getElementById('searchBtn').disabled = false;\r\n                document.getElementById('searchBtn').textContent = 'Search Components';\r\n            }\r\n        }\r\n\r\n        // Display search results\r\n        function displayResults(results) {\r\n            const container = document.getElementById('resultsContainer');\r\n\r\n            if (!results || results.length === 0) {\r\n                container.innerHTML = '<p>No results found.</p>';\r\n                document.getElementById('resultsSection').classList.remove('hidden');\r\n                return;\r\n            }\r\n\r\n            // Store all available columns for filtering/sorting\r\n            allResultColumns = Object.keys(results[0]);\r\n            setupResultControls();\r\n\r\n            const table = document.createElement('table');\r\n            table.className = 'results-table';\r\n\r\n            // Create header\r\n            const thead = document.createElement('thead');\r\n            const headerRow = document.createElement('tr');\r\n\r\n            allResultColumns.forEach(key => {\r\n                const th = document.createElement('th');\r\n                th.textContent = key.replace('_', ' ').toUpperCase();\r\n                headerRow.appendChild(th);\r\n            });\r\n\r\n            thead.appendChild(headerRow);\r\n            table.appendChild(thead);\r\n\r\n            // Create body\r\n            const tbody = document.createElement('tbody');\r\n\r\n            results.forEach(result => {\r\n                const row = document.createElement('tr');\r\n\r\n                allResultColumns.forEach(key => {\r\n                    const td = document.createElement('td');\r\n                    const value = result[key];\r\n                    td.textContent = value !== null && value !== undefined ? value : 'N/A';\r\n\r\n                    // Highlight score columns\r\n                    if (key.toLowerCase().includes('score')) {\r\n                        td.className = 'score-cell';\r\n                    }\r\n\r\n                    row.appendChild(td);\r\n                });\r\n\r\n                tbody.appendChild(row);\r\n            });\r\n\r\n            table.appendChild(tbody);\r\n\r\n            // Create dedicated table container\r\n            const tableContainer = document.createElement('div');\r\n            tableContainer.className = 'results-table-container';\r\n            tableContainer.appendChild(table);\r\n\r\n            container.innerHTML = '';\r\n            container.appendChild(tableContainer);\r\n\r\n            document.getElementById('resultsSection').classList.remove('hidden');\r\n            document.getElementById('resultControls').classList.remove('hidden');\r\n            showSuccess(`Found ${results.length} results (Session ID: ${currentSessionId})`);\r\n        }\r\n\r\n        // Setup result controls (filters, sorting, pagination)\r\n        function setupResultControls() {\r\n            // Store current values before updating\r\n            const currentSortBy = document.getElementById('sortBySelect').value;\r\n            const currentSortAsc = document.getElementById('sortAscCheckbox').checked;\r\n            const currentScoreCoupling = document.getElementById('scoreCouplingCheckbox').checked;\r\n            const currentPage = document.getElementById('pageInput').value;\r\n            const currentPerPage = document.getElementById('perPageSelect').value;\r\n\r\n            // Populate sort dropdown\r\n            const sortSelect = document.getElementById('sortBySelect');\r\n            sortSelect.innerHTML = '';\r\n            allResultColumns.forEach(col => {\r\n                const option = document.createElement('option');\r\n                option.value = col;\r\n                option.textContent = col.replace('_', ' ').toUpperCase();\r\n                // Restore previous selection or default to overall_score\r\n                if (col === currentSortBy || (col === 'overall_score' && !currentSortBy)) {\r\n                    option.selected = true;\r\n                }\r\n                sortSelect.appendChild(option);\r\n            });\r\n\r\n            // Only clear filters and reset controls on initial search (not when applying filters)\r\n            if (!document.getElementById('resultControls').classList.contains('hidden')) {\r\n                // This is a filter application, preserve current settings\r\n                document.getElementById('sortAscCheckbox').checked = currentSortAsc;\r\n                document.getElementById('scoreCouplingCheckbox').checked = currentScoreCoupling;\r\n                document.getElementById('pageInput').value = currentPage;\r\n                document.getElementById('perPageSelect').value = currentPerPage;\r\n            } else {\r\n                // This is a new search, reset everything\r\n                document.getElementById('filtersContainer').innerHTML = '';\r\n                document.getElementById('sortAscCheckbox').checked = false;\r\n                document.getElementById('scoreCouplingCheckbox').checked = false;\r\n                document.getElementById('pageInput').value = '1';\r\n                document.getElementById('perPageSelect').value = '10';\r\n            }\r\n        }\r\n\r\n        // Add a filter row\r\n        function addFilterRow() {\r\n            const container = document.getElementById('filtersContainer');\r\n            const filterItem = document.createElement('div');\r\n            filterItem.className = 'filter-item';\r\n\r\n            // Get already used parameters to prevent duplicates\r\n            const usedParams = Array.from(container.querySelectorAll('.filter-item select')).map(select => select.value).filter(val => val);\r\n\r\n            const paramSelect = document.createElement('select');\r\n            paramSelect.innerHTML = '<option value=\"\">Select parameter...</option>';\r\n            allResultColumns.forEach(col => {\r\n                // Only add if not already used\r\n                if (!usedParams.includes(col)) {\r\n                    const option = document.createElement('option');\r\n                    option.value = col;\r\n                    option.textContent = col.replace('_', ' ').toUpperCase();\r\n                    paramSelect.appendChild(option);\r\n                }\r\n            });\r\n\r\n            // Update other filter dropdowns when this one changes\r\n            paramSelect.addEventListener('change', function() {\r\n                updateFilterDropdowns();\r\n            });\r\n\r\n            const minInput = document.createElement('input');\r\n            minInput.type = 'number';\r\n            minInput.placeholder = 'Min value';\r\n\r\n            const maxInput = document.createElement('input');\r\n            maxInput.type = 'number';\r\n            maxInput.placeholder = 'Max value';\r\n\r\n            const removeBtn = document.createElement('button');\r\n            removeBtn.textContent = '×';\r\n            removeBtn.onclick = () => filterItem.remove();\r\n\r\n            filterItem.appendChild(paramSelect);\r\n\r\n            const controlRow = document.createElement('div');\r\n            controlRow.className = 'filter-controls-row';\r\n\r\n            controlRow.appendChild(minInput);\r\n            controlRow.appendChild(maxInput);\r\n            controlRow.appendChild(removeBtn);\r\n\r\n            filterItem.appendChild(controlRow);\r\n\r\n            container.appendChild(filterItem);\r\n        }\r\n\r\n        // Update filter dropdowns to prevent duplicates\r\n        function updateFilterDropdowns() {\r\n            const container = document.getElementById('filtersContainer');\r\n            const allSelects = container.querySelectorAll('.filter-item select');\r\n            const usedParams = Array.from(allSelects).map(select => select.value).filter(val => val);\r\n\r\n            allSelects.forEach(select => {\r\n                const currentValue = select.value;\r\n                select.innerHTML = '<option value=\"\">Select parameter...</option>';\r\n\r\n                allResultColumns.forEach(col => {\r\n                    // Add option if it's not used elsewhere OR it's the current selection\r\n                    if (!usedParams.includes(col) || col === currentValue) {\r\n                        const option = document.createElement('option');\r\n            